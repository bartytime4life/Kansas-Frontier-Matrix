%% KFM TRUTH PATH (Mermaid partial)
%% Purpose: Visualize how any user-visible claim becomes verifiable (or is rejected).
%% Key invariants:
%%   - Trust membrane: UI never calls databases or LLMs directly.
%%   - Promotion gates: RAW -> WORK -> PROCESSED -> PUBLISHED (fail-closed).
%%   - Evidence boundary: catalogs + checksums + provenance (DCAT/STAC/PROV + receipts).
%%   - Focus Mode and Story rendering must cite evidence or abstain.

flowchart LR
  %% -----------------------------
  %% Data lifecycle (evidence production)
  %% -----------------------------
  subgraph ZONES["Data lifecycle and evidence boundary"]
    direction TB
    S0[Upstream sources] --> S1[Acquire via connector]
    S1 --> Z_RAW[(RAW zone<br/>immutable snapshot)]
    Z_RAW --> G_RAW{Gate<br/>schema, license, sensitivity}
    G_RAW -->|pass| Z_WORK[(WORK zone<br/>staging)]
    G_RAW -->|fail| Q_RAW[Quarantine<br/>no promote]

    Z_WORK --> S2[Deterministic transforms]
    S2 --> Z_PROC[(PROCESSED zone)]
    Z_PROC --> G_PROC{Gate<br/>QA thresholds, checksums}
    G_PROC -->|pass| Z_PUB[(PUBLISHED zone)]
    G_PROC -->|fail| Q_PROC[Quarantine<br/>no promote]

    Z_PUB --> CAT[Catalog triplet<br/>DCAT + STAC + PROV]
    CAT --> EVID[Evidence record<br/>digests, signatures, receipts]
  end

  %% -----------------------------
  %% Serving + reasoning (evidence consumption)
  %% -----------------------------
  subgraph MEM["Trust membrane and governed serving"]
    direction TB
    UI[UI request<br/>map, story, focus] --> API[Governed API]
    API --> AUTH[AuthN + AuthZ]
    AUTH --> POL[Policy pre-check<br/>default deny]

    POL -->|deny| DENY[Return deny<br/>or redaction]
    POL -->|allow| PLAN[Retrieval plan]

    PLAN --> RET[Retrieve admissible evidence<br/>PUBLISHED only]
    RET --> BUNDLE[Resolve EvidenceBundle<br/>ids, versions, cites]

    BUNDLE --> GEN[Render or synthesize<br/>LLM draft allowed]
    GEN --> VERIFY{Citation verification<br/>hard gate}

    VERIFY -->|pass| OUT[Emit response<br/>with citations]
    VERIFY -->|fail| ABSTAIN[Abstain<br/>or reduce scope]

    OUT --> RECEIPT[Emit run receipt<br/>run_id, audit_ref]
  end

  %% -----------------------------
  %% Storage (behind adapters only)
  %% -----------------------------
  API --> ADAPT[Repository and adapters]
  ADAPT --> PG[(PostGIS)]
  ADAPT --> GDB[(Neo4j)]
  ADAPT --> IDX[(Search index)]
  ADAPT --> OBJ[(Artifact store<br/>files, tiles, docs)]

  %% Evidence boundary wiring
  Z_PUB --> OBJ
  CAT --> OBJ
  EVID --> RET
  RET --> ADAPT
