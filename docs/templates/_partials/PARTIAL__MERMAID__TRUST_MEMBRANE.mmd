%% [KFM_MERMAID_PARTIAL]
%% id: PARTIAL__MERMAID__TRUST_MEMBRANE
%% purpose: Visualize the KFM trust membrane and enforced runtime access paths.
%% invariants:
%%   - UI and external clients never access datastores directly.
%%   - All access crosses the governed API and policy boundary (default-deny).
%%   - Core logic reaches storage only through repository/adapter interfaces.
%%   - Focus Mode returns answers with evidence, citations, and an audit reference (or abstains).

flowchart LR

  %% ------------------------------
  %% ZONES
  %% ------------------------------

  subgraph UZ[Untrusted zone]
    UI[UI client<br/>Map Timeline Story Focus]
    EXT[External clients<br/>CLI SDK Integrations]
  end

  subgraph TM[Trust membrane<br/>API and policy boundary]
    INGRESS[HTTPS ingress<br/>rate limit logging]
    AUTH[AuthN AuthZ<br/>scopes and roles]
    OPA[Policy check<br/>OPA default deny]
  end

  subgraph GZ[Governed services]
    API[Governed API<br/>FastAPI GraphQL]

    subgraph FOCUSZ[Focus Mode]
      FOCUS[Focus orchestrator]
      RETR[Evidence retrieval]
      PROMPT[Prompt assembly]
      CITE[Citation and grounding gate]
      AUDIT[Audit reference<br/>run receipt]
    end

    REPO[Repository and adapters]
  end

  subgraph STORES[Knowledge stores and catalogs]
    N4J[Neo4j<br/>knowledge graph]
    PG[PostGIS<br/>spatial]
    IDX[Search index<br/>text vector]
    OBJ[Object store<br/>RAW WORK PROCESSED PUBLISHED]
    CAT[Catalog triplet<br/>DCAT STAC PROV]
  end

  subgraph MODEL[Model runtime]
    OLL[Ollama LLM service]
  end

  %% ------------------------------
  %% ALLOWED REQUEST PATHS
  %% ------------------------------

  UI --> INGRESS
  EXT --> INGRESS

  INGRESS --> AUTH --> OPA

  OPA -->|allow| API
  OPA -->|deny| DENY[Deny or redact<br/>fail closed]

  %% ------------------------------
  %% GOVERNED DATA ACCESS
  %% ------------------------------

  API --> REPO
  REPO --> N4J
  REPO --> PG
  REPO --> IDX
  REPO --> OBJ
  REPO --> CAT

  %% ------------------------------
  %% FOCUS MODE ORCHESTRATION
  %% ------------------------------

  API --> FOCUS

  FOCUS --> RETR --> REPO
  FOCUS --> PROMPT
  RETR --> PROMPT

  PROMPT --> OLL --> CITE
  RETR --> CITE

  CITE -->|pass| AUDIT --> API
  CITE -->|fail| ABSTAIN[Abstain or narrow scope<br/>cite or abstain] --> API

  API -->|response| UI
  API -->|response| EXT

  DENY -->|response| UI
  DENY -->|response| EXT

  %% ------------------------------
  %% FORBIDDEN DIRECT PATHS
  %% ------------------------------

  UI -. NO DIRECT .-> N4J
  UI -. NO DIRECT .-> PG
  UI -. NO DIRECT .-> OBJ
  UI -. NO DIRECT .-> OLL

  EXT -. NO DIRECT .-> N4J
  EXT -. NO DIRECT .-> PG
  EXT -. NO DIRECT .-> OBJ
  EXT -. NO DIRECT .-> OLL

  OLL -. NO DIRECT .-> N4J
  OLL -. NO DIRECT .-> PG
  OLL -. NO DIRECT .-> OBJ

  %% ------------------------------
  %% STYLES
  %% ------------------------------

  classDef untrusted fill:#fff5f5,stroke:#c53030,stroke-width:1px
  classDef membrane fill:#f7fafc,stroke:#2b6cb0,stroke-width:2px
  classDef governed fill:#f0fff4,stroke:#2f855a,stroke-width:1px
  classDef store fill:#ebf8ff,stroke:#2b6cb0,stroke-width:1px
  classDef model fill:#faf5ff,stroke:#6b46c1,stroke-width:1px
  classDef warn fill:#fffaf0,stroke:#b7791f,stroke-width:2px

  class UI,EXT untrusted
  class INGRESS,AUTH,OPA membrane
  class API,FOCUS,RETR,PROMPT,CITE,AUDIT,REPO governed
  class N4J,PG,IDX,OBJ,CAT store
  class OLL model
  class DENY,ABSTAIN warn
