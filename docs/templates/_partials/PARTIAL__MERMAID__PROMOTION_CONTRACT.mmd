graph LR
  U[Upstream sources] --> RAW["RAW zone<br/>immutable acquisition<br/>artifacts and checksums<br/>license snapshot"]
  RAW --> WORK["WORK zone<br/>normalize and QA<br/>redaction candidates"]
  WORK --> PROC["PROCESSED zone<br/>publishable formats<br/>stable IDs and checksums"]
  PROC --> CAT["CATALOG triplet<br/>DCAT + STAC + PROV<br/>cross-linked IDs"]

  CAT --> DECIDE{Promotion Contract gates pass?}
  DECIDE -->|yes| PUB["PUBLISHED surfaces<br/>Governed API and UI<br/>policy enforced"]
  DECIDE -->|no| QUAR["QUARANTINE<br/>blocked from promotion<br/>fix issues then rerun"]
  QUAR -->|remediate and re-run| WORK

  subgraph G["Promotion Contract v1: minimum gates"]
    GA["Gate A<br/>Identity and versioning<br/>dataset_id, dataset_version_id, spec_hash, digests"]
    GB["Gate B<br/>Licensing and rights metadata<br/>license fields and upstream terms snapshot"]
    GC["Gate C<br/>Sensitivity and redaction plan<br/>policy_label and obligations"]
    GD["Gate D<br/>Catalog triplet validation<br/>DCAT, STAC, PROV validate<br/>EvidenceRefs resolve"]
    GE["Gate E<br/>QA and thresholds<br/>dataset-specific checks documented"]
    GF["Gate F<br/>Run receipt and audit record<br/>inputs, tooling, hashes, policy decisions<br/>signature checks when enabled"]
    GG["Gate G<br/>Release manifest<br/>promotion recorded with artifact digests"]
  end

  GA -->|required| DECIDE
  GB -->|required| DECIDE
  GC -->|required| DECIDE
  GD -->|required| DECIDE
  GE -->|required| DECIDE
  GF -->|required| DECIDE
  GG -->|required| DECIDE

  ENF["Enforcement<br/>CI validators and linkcheck<br/>OPA default-deny<br/>steward sign-off"] --> DECIDE
