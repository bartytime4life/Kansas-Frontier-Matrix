## `pipelines/kansas_biodiversity_etl/normalize/normalize_dwc.py`

```python
#!/usr/bin/env python3
"""
Normalize Darwin Core occurrence JSONL into KFM canonical occurrence JSONL.

Contract:
- Input: JSONL records using Darwin Core-like field names.
- Output: deterministic canonical JSONL.
- Hash: per-record spec_hash from sorted canonical JSON excluding transient fields.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import sys
from pathlib import Path
from typing import Any, Dict, Iterable, Optional


TRANSIENT_FIELDS = {"spec_hash"}


def sha256_json(value: Dict[str, Any]) -> str:
    stable = {
        key: value[key]
        for key in sorted(value.keys())
        if key not in TRANSIENT_FIELDS
    }
    payload = json.dumps(stable, sort_keys=True, separators=(",", ":"), ensure_ascii=False)
    return "sha256:" + hashlib.sha256(payload.encode("utf-8")).hexdigest()


def to_float(value: Any) -> Optional[float]:
    if value in (None, ""):
        return None
    try:
        return float(value)
    except (TypeError, ValueError):
        return None


def normalize_record(raw: Dict[str, Any]) -> Dict[str, Any]:
    lat = to_float(raw.get("decimalLatitude"))
    lon = to_float(raw.get("decimalLongitude"))

    if lat is None or lon is None:
        raise ValueError("missing_or_invalid_coordinates")

    if not (-90 <= lat <= 90 and -180 <= lon <= 180):
        raise ValueError("coordinates_out_of_range")

    canonical: Dict[str, Any] = {
        "id": raw.get("catalogNumber"),
        "taxon": raw.get("scientificName"),
        "event_date": raw.get("eventDate"),
        "geometry": {
            "type": "Point",
            "coordinates": [lon, lat],
            "crs": "EPSG:4326",
        },
        "uncertainty_m": to_float(raw.get("coordinateUncertaintyInMeters")),
        "institution_code": raw.get("institutionCode"),
        "collection_code": raw.get("collectionCode"),
        "basis_of_record": raw.get("basisOfRecord"),
        "license_raw": raw.get("license"),
        "rights_holder": raw.get("rightsHolder"),
    }

    canonical["spec_hash"] = sha256_json(canonical)
    return canonical


def read_jsonl(path: Path) -> Iterable[Dict[str, Any]]:
    with path.open("r", encoding="utf-8") as handle:
        for line_number, line in enumerate(handle, start=1):
            stripped = line.strip()
            if not stripped:
                continue
            try:
                yield json.loads(stripped)
            except json.JSONDecodeError as exc:
                raise ValueError(f"invalid_json_line:{line_number}") from exc


def write_jsonl(records: Iterable[Dict[str, Any]], output_path: Path) -> int:
    output_path.parent.mkdir(parents=True, exist_ok=True)
    count = 0
    with output_path.open("w", encoding="utf-8") as handle:
        for record in records:
            handle.write(json.dumps(record, sort_keys=True, separators=(",", ":"), ensure_ascii=False))
            handle.write("\n")
            count += 1
    return count


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--input", required=True, help="Input DwC JSONL file")
    parser.add_argument("--output", required=True, help="Output canonical JSONL file")
    parser.add_argument(
        "--quarantine",
        default="data/quarantine/kansas_biodiversity_etl/quarantine.jsonl",
        help="Path for rejected records",
    )
    args = parser.parse_args()

    input_path = Path(args.input)
    output_path = Path(args.output)
    quarantine_path = Path(args.quarantine)
    quarantine_path.parent.mkdir(parents=True, exist_ok=True)

    accepted = []
    rejected = 0

    with quarantine_path.open("w", encoding="utf-8") as quarantine:
        for raw in read_jsonl(input_path):
            try:
                accepted.append(normalize_record(raw))
            except ValueError as exc:
                rejected += 1
                quarantine.write(json.dumps({"reason": str(exc), "raw": raw}, sort_keys=True))
                quarantine.write("\n")

    count = write_jsonl(accepted, output_path)

    print(
        json.dumps(
            {
                "accepted": count,
                "rejected": rejected,
                "output": str(output_path),
                "quarantine": str(quarantine_path),
            },
            sort_keys=True,
        )
    )

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
```

