## `pipelines/kansas_biodiversity_etl/Makefile`

```makefile
SHELL := /bin/bash

RAW_SAMPLE := samples/dwc_occurrences_sample.jsonl
WORK_DIR := ../../data/work/kansas_biodiversity_etl
PROCESSED_DIR := ../../data/processed/kansas_occurrences
RECEIPTS_DIR := ../../data/receipts/kansas_biodiversity_etl/20260425
PROOFS_DIR := ../../data/proofs/kansas_biodiversity_etl/20260425

NORMALIZED := $(WORK_DIR)/normalized.jsonl
DATASET := $(PROCESSED_DIR)/part-000.jsonl
EVIDENCE := $(PROOFS_DIR)/evidence_bundle.json
RECEIPT := $(RECEIPTS_DIR)/run_receipt.json

.PHONY: all normalize publish gate clean

all: normalize publish gate

normalize:
	python normalize/normalize_dwc.py \
		--input $(RAW_SAMPLE) \
		--output $(NORMALIZED)

publish:
	python publish/publish.py \
		--input $(NORMALIZED) \
		--dataset-output $(DATASET) \
		--evidence-output $(EVIDENCE) \
		--receipt-output $(RECEIPT) \
		--source-uri "sample://pipelines/kansas_biodiversity_etl/samples/dwc_occurrences_sample.jsonl"

gate:
	python validate/promotion_gate_min.py \
		--dataset $(DATASET) \
		--evidence $(EVIDENCE)

clean:
	rm -rf $(WORK_DIR) $(PROCESSED_DIR) $(RECEIPTS_DIR) $(PROOFS_DIR)
```

