## `pipelines/kansas_biodiversity_etl/publish/publish.py`

```python
#!/usr/bin/env python3
"""
Publish normalized Kansas biodiversity occurrences into processed artifacts.

Thin-slice behavior:
- Reads canonical JSONL.
- Writes processed JSONL as the dataset artifact.
- Computes dataset spec_hash.
- Emits EvidenceBundle.
- Emits run receipt.

Parquet can replace JSONL later without changing the governance boundary.
"""

from __future__ import annotations

import argparse
import hashlib
import json
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List


def utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return "sha256:" + digest.hexdigest()


def read_jsonl(path: Path) -> List[Dict[str, Any]]:
    records: List[Dict[str, Any]] = []
    with path.open("r", encoding="utf-8") as handle:
        for line in handle:
            stripped = line.strip()
            if stripped:
                records.append(json.loads(stripped))
    return records


def write_jsonl(records: List[Dict[str, Any]], path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        for record in records:
            handle.write(json.dumps(record, sort_keys=True, separators=(",", ":"), ensure_ascii=False))
            handle.write("\n")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--input", required=True, help="Canonical normalized JSONL")
    parser.add_argument("--dataset-output", required=True, help="Processed dataset output JSONL")
    parser.add_argument("--evidence-output", required=True, help="EvidenceBundle JSON output")
    parser.add_argument("--receipt-output", required=True, help="Run receipt JSON output")
    parser.add_argument("--source-uri", action="append", required=True, help="Source URI; may be repeated")
    parser.add_argument("--dataset-id", default="kfm:kansas_biodiversity_occurrences:thin_slice")
    parser.add_argument("--license", default="CC0/CC-BY-4.0")
    parser.add_argument("--attribution", default="Kansas biodiversity occurrence providers via GBIF/DwC-A")
    args = parser.parse_args()

    input_path = Path(args.input)
    dataset_path = Path(args.dataset_output)
    evidence_path = Path(args.evidence_output)
    receipt_path = Path(args.receipt_output)

    records = read_jsonl(input_path)
    write_jsonl(records, dataset_path)

    dataset_hash = sha256_file(dataset_path)
    generated_at = utc_now()

    evidence_bundle = {
        "evidenceBundle": {
            "spec_hash": dataset_hash,
            "dataset_id": args.dataset_id,
            "harvest_date": generated_at,
            "items": len(records),
            "source_uris": args.source_uri,
            "license": args.license,
            "attribution": args.attribution,
            "obligations": [
                "retain attribution",
                "fail closed on unknown license",
                "redact sensitive coordinates before publication",
            ],
        }
    }

    evidence_path.parent.mkdir(parents=True, exist_ok=True)
    evidence_path.write_text(
        json.dumps(evidence_bundle, indent=2, sort_keys=True, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )

    receipt = {
        "candidate": str(dataset_path),
        "decision": "generated_not_promoted",
        "generated_at": generated_at,
        "spec_hash": dataset_hash,
        "items": len(records),
        "evidence_bundle": str(evidence_path),
        "source_uris": args.source_uri,
        "attestation_verified": False,
        "notes": [
            "Thin-slice receipt.",
            "Signature/DSSE integration remains NEEDS VERIFICATION until wired.",
        ],
    }

    receipt_path.parent.mkdir(parents=True, exist_ok=True)
    receipt_path.write_text(
        json.dumps(receipt, indent=2, sort_keys=True, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )

    print(json.dumps(receipt, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
```

