## `pipelines/kansas_biodiversity_etl/validate/promotion_gate_min.py`

```python
#!/usr/bin/env python3
"""
Minimal fail-closed promotion gate for the Kansas Biodiversity ETL thin slice.

Checks:
1. Dataset artifact exists.
2. EvidenceBundle exists.
3. EvidenceBundle spec_hash matches dataset hash.
4. Item count is positive.
5. Source URIs are present.
"""

from __future__ import annotations

import argparse
import hashlib
import json
from pathlib import Path
from typing import Any, Dict


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return "sha256:" + digest.hexdigest()


def fail(reason: str) -> int:
    print(json.dumps({"decision": "FAIL", "reason": reason}, sort_keys=True))
    return 1


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--dataset", required=True)
    parser.add_argument("--evidence", required=True)
    args = parser.parse_args()

    dataset_path = Path(args.dataset)
    evidence_path = Path(args.evidence)

    if not dataset_path.exists():
        return fail("dataset_missing")

    if not evidence_path.exists():
        return fail("evidencebundle_missing")

    try:
        evidence_doc: Dict[str, Any] = json.loads(evidence_path.read_text(encoding="utf-8"))
        bundle = evidence_doc["evidenceBundle"]
    except Exception:
        return fail("invalid_evidencebundle_json")

    actual_hash = sha256_file(dataset_path)
    expected_hash = bundle.get("spec_hash")

    if actual_hash != expected_hash:
        return fail("spec_hash_mismatch")

    if int(bundle.get("items", 0)) <= 0:
        return fail("empty_dataset")

    if not bundle.get("source_uris"):
        return fail("missing_source_uris")

    print(
        json.dumps(
            {
                "decision": "PASS",
                "dataset": str(dataset_path),
                "evidence": str(evidence_path),
                "spec_hash": actual_hash,
                "items": bundle.get("items"),
            },
            sort_keys=True,
        )
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
```

