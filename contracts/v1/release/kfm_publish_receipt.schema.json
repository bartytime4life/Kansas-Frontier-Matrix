{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schema/contracts/v1/release/kfm_publish_receipt.schema.json",
  "title": "KFM PublishReceipt",
  "description": "Receipt emitted after a successful publish_release execution. Records closure status, release identity, and publish plan.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_type",
    "created_at",
    "status",
    "mode",
    "plan"
  ],
  "properties": {
    "receipt_type": {
      "type": "string",
      "const": "kfm:PublishReceipt"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "const": "PUBLISHED"
    },
    "mode": {
      "type": "string",
      "enum": [
        "local-receipt-only",
        "publish-dry-run",
        "publish"
      ]
    },
    "plan": {
      "$ref": "#/$defs/plan"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_id",
        "manifest_id",
        "policy_label",
        "review_state",
        "artifact_count",
        "closure_status",
        "artifacts"
      ],
      "properties": {
        "release_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "manifest_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "manifest_path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "policy_label": {
          "type": "string",
          "const": "public"
        },
        "review_state": {
          "type": "string",
          "enum": ["reviewed", "published"]
        },
        "spec_hash": {
          "$ref": "#/$defs/sha256"
        },
        "artifact_count": {
          "type": "integer",
          "minimum": 1
        },
        "closure_status": {
          "type": "string",
          "const": "PUBLISHABLE"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifact"
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_ref",
        "evidence_ref",
        "provenance_ref",
        "stac_ref",
        "dcat_ref"
      ],
      "properties": {
        "artifact_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "evidence_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "provenance_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "stac_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dcat_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "attestation_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "run_receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
