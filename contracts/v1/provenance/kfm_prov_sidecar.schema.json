{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schema/contracts/v1/provenance/kfm_prov_sidecar.schema.json",
  "title": "KFM PROV Sidecar",
  "description": "KFM provenance sidecar for EvidenceBundle outputs, pipeline runs, receipt references, and catalog-linked public artifacts.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "@context",
    "entity",
    "activity",
    "agent",
    "wasGeneratedBy",
    "wasAttributedTo"
  ],
  "properties": {
    "@context": {
      "type": "object",
      "required": ["prov", "dct", "kfm"],
      "properties": {
        "prov": {
          "const": "http://www.w3.org/ns/prov#"
        },
        "dct": {
          "const": "http://purl.org/dc/terms/"
        },
        "kfm": {
          "type": "string",
          "minLength": 1
        },
        "spdx": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "entity": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z0-9_:-]+$": {
          "$ref": "#/$defs/entity"
        }
      },
      "additionalProperties": false
    },
    "activity": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z0-9_:-]+$": {
          "$ref": "#/$defs/activity"
        }
      },
      "additionalProperties": false
    },
    "agent": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z0-9_:-]+$": {
          "$ref": "#/$defs/agent"
        }
      },
      "additionalProperties": false
    },
    "wasGeneratedBy": {
      "$ref": "#/$defs/wasGeneratedBy"
    },
    "wasAttributedTo": {
      "$ref": "#/$defs/wasAttributedTo"
    },
    "wasDerivedFrom": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/wasDerivedFrom"
      }
    },
    "used": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/used"
      }
    },
    "kfm:publication_context": {
      "type": "string",
      "enum": ["public", "restricted", "internal", "deny"]
    },
    "kfm:release_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "kfm:catalog_refs": {
      "type": "object",
      "properties": {
        "stac": {
          "type": "string",
          "minLength": 1
        },
        "dcat": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonTodoString": {
      "type": "string",
      "minLength": 1,
      "not": {
        "enum": ["TODO", "todo", "UNKNOWN", "unknown", "NEEDS-VERIFICATION"]
      }
    },
    "uriOrRef": {
      "type": "string",
      "minLength": 1
    },
    "policyLabel": {
      "type": "string",
      "enum": ["public", "restricted", "internal", "deny", "TODO"]
    },
    "reviewState": {
      "type": "string",
      "enum": ["draft", "review", "reviewed", "published", "superseded", "retracted", "TODO"]
    },
    "entity": {
      "type": "object",
      "required": ["prov:type"],
      "properties": {
        "prov:type": {
          "type": "string",
          "minLength": 1
        },
        "dct:identifier": {
          "$ref": "#/$defs/uriOrRef"
        },
        "dct:title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dct:description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dct:license": {
          "$ref": "#/$defs/nonTodoString"
        },
        "dct:accessRights": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dct:created": {
          "type": "string",
          "format": "date-time"
        },
        "dct:modified": {
          "type": "string",
          "format": "date-time"
        },
        "prov:generatedAtTime": {
          "type": "string",
          "format": "date-time"
        },
        "kfm:spec_hash": {
          "$ref": "#/$defs/sha256"
        },
        "kfm:content_spec_hash": {
          "$ref": "#/$defs/sha256"
        },
        "kfm:geometry_hash": {
          "$ref": "#/$defs/sha256"
        },
        "kfm:evidence_ref": {
          "$ref": "#/$defs/uriOrRef"
        },
        "kfm:run_receipt_ref": {
          "$ref": "#/$defs/uriOrRef"
        },
        "kfm:ai_receipt_ref": {
          "$ref": "#/$defs/uriOrRef"
        },
        "kfm:redaction_receipt_ref": {
          "$ref": "#/$defs/uriOrRef"
        },
        "kfm:release_manifest_ref": {
          "$ref": "#/$defs/uriOrRef"
        },
        "kfm:policy_label": {
          "$ref": "#/$defs/policyLabel"
        },
        "kfm:review_state": {
          "$ref": "#/$defs/reviewState"
        },
        "kfm:source_role": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kfm:sensitivity": {
          "type": "string",
          "enum": ["public", "restricted", "sensitive", "deny", "unknown", "TODO"]
        }
      },
      "additionalProperties": true
    },
    "activity": {
      "type": "object",
      "required": ["prov:type", "prov:endedAtTime"],
      "properties": {
        "prov:type": {
          "type": "string",
          "minLength": 1
        },
        "prov:used": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uriOrRef"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "prov:startedAtTime": {
          "type": "string",
          "format": "date-time"
        },
        "prov:endedAtTime": {
          "type": "string",
          "format": "date-time"
        },
        "kfm:pipeline": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kfm:pipeline_version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kfm:run_receipt_ref": {
          "$ref": "#/$defs/uriOrRef"
        },
        "kfm:execution_environment": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "agent": {
      "type": "object",
      "required": ["prov:type"],
      "properties": {
        "prov:type": {
          "type": "string",
          "minLength": 1
        },
        "dct:identifier": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kfm:agent_role": {
          "type": "string",
          "enum": ["signer", "reviewer", "pipeline", "service", "human", "TODO"]
        }
      },
      "additionalProperties": true
    },
    "wasGeneratedBy": {
      "type": "object",
      "required": ["prov:entity", "prov:activity"],
      "properties": {
        "prov:entity": {
          "$ref": "#/$defs/uriOrRef"
        },
        "prov:activity": {
          "$ref": "#/$defs/uriOrRef"
        },
        "prov:time": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "wasAttributedTo": {
      "type": "object",
      "required": ["prov:entity", "prov:agent"],
      "properties": {
        "prov:entity": {
          "$ref": "#/$defs/uriOrRef"
        },
        "prov:agent": {
          "$ref": "#/$defs/uriOrRef"
        }
      },
      "additionalProperties": true
    },
    "wasDerivedFrom": {
      "type": "object",
      "required": ["prov:generatedEntity", "prov:usedEntity"],
      "properties": {
        "prov:generatedEntity": {
          "$ref": "#/$defs/uriOrRef"
        },
        "prov:usedEntity": {
          "$ref": "#/$defs/uriOrRef"
        },
        "prov:activity": {
          "$ref": "#/$defs/uriOrRef"
        }
      },
      "additionalProperties": true
    },
    "used": {
      "type": "object",
      "required": ["prov:activity", "prov:entity"],
      "properties": {
        "prov:activity": {
          "$ref": "#/$defs/uriOrRef"
        },
        "prov:entity": {
          "$ref": "#/$defs/uriOrRef"
        },
        "prov:role": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    }
  }
}
