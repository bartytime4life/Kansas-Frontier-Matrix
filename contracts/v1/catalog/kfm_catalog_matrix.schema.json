{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schema/contracts/v1/catalog/kfm_catalog_matrix.schema.json",
  "title": "KFM CatalogMatrix",
  "description": "Closure graph linking artifact, provenance, evidence, STAC, DCAT, ReleaseManifest, and PublishReceipt for audit, debugging, and UI consumption.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "matrix_id",
    "created_at",
    "status",
    "artifact",
    "provenance",
    "evidence",
    "stac",
    "dcat",
    "release",
    "publish_receipt"
  ],
  "properties": {
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["closed", "abstain", "deny", "error"]
    },
    "artifact": {
      "$ref": "#/$defs/refObject"
    },
    "provenance": {
      "$ref": "#/$defs/refObject"
    },
    "evidence": {
      "$ref": "#/$defs/refObject"
    },
    "stac": {
      "$ref": "#/$defs/refObject"
    },
    "dcat": {
      "$ref": "#/$defs/refObject"
    },
    "release": {
      "$ref": "#/$defs/refObject"
    },
    "publish_receipt": {
      "$ref": "#/$defs/refObject"
    },
    "spec_hash": {
      "$ref": "#/$defs/sha256"
    },
    "policy_label": {
      "type": "string",
      "const": "public"
    },
    "review_state": {
      "type": "string",
      "enum": ["reviewed", "published"]
    },
    "sensitivity": {
      "type": "string",
      "enum": ["public"]
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "refObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "resolved": {
          "type": "boolean"
        },
        "kind": {
          "type": "string",
          "enum": [
            "artifact",
            "provenance",
            "evidence",
            "stac",
            "dcat",
            "release",
            "publish_receipt",
            "unknown"
          ]
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_ref",
        "evidence_ref",
        "provenance_ref",
        "stac_ref",
        "dcat_ref",
        "release_ref",
        "publish_receipt_ref"
      ],
      "properties": {
        "artifact_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "evidence_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "provenance_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "stac_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dcat_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "release_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "publish_receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "attestation_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "run_receipt_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
