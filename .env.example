# KFM environment example — copy to .env and fill carefully.
# Never commit real secrets. configs/local/ is .gitignored.

KFM_ENV=dev
KFM_LOG_LEVEL=info

# Governed API
KFM_API_BIND=127.0.0.1
KFM_API_PORT=8080

# Model runtime — subordinate to governed API; never publicly exposed
KFM_MODEL_RUNTIME=mock
OLLAMA_HOST=http://127.0.0.1:11434
