# Kansas Frontier Matrix local environment template
#
# Copy this file for local development:
#   cp .env.example .env
#
# Safety:
# - `.env` and `configs/local/*` are ignored; never commit real secrets.
# - Keep API and model-runtime endpoints loopback-only unless reviewed
#   infrastructure and policy explicitly authorize another exposure posture.
# - Browser and public clients must use the governed API, never Ollama or a
#   model runtime directly.
#
# Evidence boundary:
# - These are safe example values and references-by-name only.
# - This file does not prove that a loader, daemon, provider, deployment, or
#   release is implemented or active.

# Core local posture
KFM_ENV=dev
KFM_LOG_LEVEL=info

# Governed API — loopback by default
KFM_API_BIND=127.0.0.1
KFM_API_PORT=8080

# Optional deterministic timestamp for tests or replay.
# Leave unset during normal runs so the current stub uses the current UTC time.
# GOVERNED_API_ISSUED_AT=2026-05-09T00:00:00+00:00

# Model runtime — mock first and subordinate to the governed API.
# The current readiness workflow requires this exact default.
KFM_MODEL_RUNTIME=mock

# Ollama endpoint — inactive while KFM_MODEL_RUNTIME=mock.
# Keep loopback-only; do not expose this endpoint to browsers or public clients.
OLLAMA_HOST=http://127.0.0.1:11434

# Source credentials and signing material
# Add only variables required by a named consumer in your untracked `.env` or
# approved external secret store. Never place real values in this template.
