{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReleaseManifest starter schema",
  "type": "object",
  "required": [
    "release_id",
    "version",
    "target_env",
    "spec_hash",
    "artifacts",
    "evidence_bundle_ref",
    "decision_log_ref"
  ],
  "properties": {
    "release_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "target_env": {
      "enum": [
        "staging",
        "prod"
      ]
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        }
      }
    },
    "evidence_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision_log_ref": {
      "type": "string",
      "minLength": 1
    }
  }
}
