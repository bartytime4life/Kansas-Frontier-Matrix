{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "query_id",
    "query_type",
    "request_public",
    "include_geometry",
    "include_ui_cards",
    "created_at",
    "kfm:spec_hash"
  ],
  "properties": {
    "query_id": {
      "type": "string"
    },
    "query_type": {
      "enum": [
        "taxa_in_geography",
        "geographies_for_taxon",
        "evidence_for_taxon_geography",
        "exact_coordinates",
        "confirmed_presence"
      ]
    },
    "taxon_key": {
      "type": "string"
    },
    "scientific_name": {
      "type": "string"
    },
    "geography_id": {
      "type": "string"
    },
    "aggregation_unit": {
      "enum": [
        "county",
        "huc12",
        "grid"
      ]
    },
    "request_public": {
      "type": "boolean"
    },
    "include_geometry": {
      "type": "boolean"
    },
    "include_ui_cards": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string"
    },
    "kfm:spec_hash": {
      "type": "string"
    }
  }
}