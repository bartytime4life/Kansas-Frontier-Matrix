{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.dev/schemas/tile_runtime/tile_runtime_performance_receipt.schema.json",
  "title": "TileRuntimePerformanceReceipt.v1",
  "type": "object",
  "required": ["schema_version","receipt_id","run_id","created_at","harness_version","runtime_profile","cpu_throttle","network_profile","verifier_worker_count","max_parallel_fetches","tile_count","verified_tile_count","failed_tile_count","mean_verify_decode_ms","p95_verify_decode_ms","peak_renderer_memory_mb","budget","budget_decision","failure_reasons","trace_manifest_ref","release_manifest_ref","evidence_bundle_refs","policy_label","public_safe","spec_hash"],
  "properties": {
    "schema_version": {"const": "TileRuntimePerformanceReceipt.v1"},
    "receipt_id": {"type": "string", "pattern": "^trpr_[a-f0-9]{16}$"},
    "run_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "harness_version": {"type": "string"},
    "runtime_profile": {"type": "string"},
    "cpu_throttle": {"type": "number", "minimum": 0},
    "network_profile": {"type": "string"},
    "verifier_worker_count": {"type": "integer", "minimum": 1},
    "max_parallel_fetches": {"type": "integer", "minimum": 1},
    "tile_count": {"type": "integer", "minimum": 0},
    "verified_tile_count": {"type": "integer", "minimum": 0},
    "failed_tile_count": {"type": "integer", "minimum": 0},
    "mean_verify_decode_ms": {"type": "number", "minimum": 0},
    "p95_verify_decode_ms": {"type": "number", "minimum": 0},
    "peak_renderer_memory_mb": {"type": "number", "minimum": 0},
    "budget": {"type": "object"},
    "budget_decision": {"enum": ["allow", "deny"]},
    "failure_reasons": {"type": "array", "items": {"type": "string"}},
    "trace_manifest_ref": {"type": "string", "minLength": 1},
    "release_manifest_ref": {"type": "string", "minLength": 1},
    "evidence_bundle_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "policy_label": {"type": "string"},
    "public_safe": {"type": "boolean"},
    "spec_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
