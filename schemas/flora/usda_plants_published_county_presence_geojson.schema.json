{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "features": {
      "type": "array"
    },
    "metadata": {
      "additionalProperties": false,
      "properties": {
        "citation_text": {
          "type": "string"
        },
        "contains_county_boundary_geometry": {
          "const": true
        },
        "contains_occurrence_coordinates": {
          "const": false
        },
        "contains_vector_tiles": {
          "const": false
        },
        "domain": {
          "const": "flora"
        },
        "generated_at": {
          "type": "string"
        },
        "geojson_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "geometry_authority": {
          "type": "string"
        },
        "join_key": {
          "const": "fips"
        },
        "object_type": {
          "const": "usda_plants_published_county_presence_geojson"
        },
        "publication_state": {
          "const": "published"
        },
        "schema_version": {
          "const": "1.0.0"
        },
        "snapshot_date": {
          "type": "string"
        },
        "source_id": {
          "const": "usda_plants"
        }
      },
      "required": [
        "object_type",
        "schema_version",
        "domain",
        "source_id",
        "snapshot_date",
        "generated_at",
        "join_key",
        "geometry_authority",
        "publication_state",
        "contains_county_boundary_geometry",
        "contains_occurrence_coordinates",
        "contains_vector_tiles",
        "citation_text",
        "geojson_hash"
      ],
      "type": "object"
    },
    "type": {
      "const": "FeatureCollection"
    }
  },
  "required": [
    "type",
    "metadata",
    "features"
  ],
  "type": "object"
}
