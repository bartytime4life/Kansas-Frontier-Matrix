{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_geometry_types": {
      "items": {
        "enum": [
          "Polygon",
          "MultiPolygon"
        ]
      },
      "type": "array"
    },
    "domain": {
      "const": "flora"
    },
    "geometry_authority": {
      "additionalProperties": false,
      "properties": {
        "authority_id": {
          "type": "string"
        },
        "authority_name": {
          "type": "string"
        },
        "authority_uri": {
          "type": "string"
        },
        "citation_required": {
          "const": true
        },
        "citation_text": {
          "type": "string"
        },
        "rights_status": {
          "const": "public"
        }
      },
      "required": [
        "authority_id",
        "authority_name",
        "authority_uri",
        "rights_status",
        "citation_required",
        "citation_text"
      ],
      "type": "object"
    },
    "geometry_generalization": {
      "type": "string"
    },
    "geometry_level": {
      "const": "county"
    },
    "geometry_source_id": {
      "type": "string"
    },
    "geometry_vintage": {
      "type": "string"
    },
    "join_key": {
      "const": "fips"
    },
    "network_mode": {
      "enum": [
        "disabled",
        "manual_enabled"
      ]
    },
    "object_type": {
      "const": "usda_plants_county_geometry_source"
    },
    "reason_codes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "snapshot_date": {
      "format": "date",
      "type": "string"
    },
    "source_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "source_id": {
      "const": "usda_plants"
    },
    "state_filter": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "status": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "object_type",
    "geometry_source_id",
    "domain",
    "source_id",
    "geometry_authority",
    "snapshot_date",
    "geometry_vintage",
    "geometry_level",
    "geometry_generalization",
    "allowed_geometry_types",
    "join_key",
    "state_filter",
    "network_mode",
    "status",
    "reason_codes",
    "source_hash"
  ],
  "type": "object"
}
