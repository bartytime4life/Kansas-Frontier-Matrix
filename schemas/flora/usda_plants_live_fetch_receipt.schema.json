{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "ci": {
      "type": "boolean"
    },
    "domain": {
      "const": "flora"
    },
    "downloaded_files": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "etag": {
            "type": [
              "string",
              "null"
            ]
          },
          "http_status": {
            "type": "integer"
          },
          "last_modified": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "sha256": {
            "pattern": "^sha256:[a-f0-9]{64}$",
            "type": "string"
          },
          "size_bytes": {
            "minimum": 0,
            "type": "integer"
          },
          "status": {
            "enum": [
              "downloaded",
              "failed",
              "quarantined"
            ]
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "role",
          "url",
          "path",
          "status",
          "http_status",
          "size_bytes",
          "sha256",
          "etag",
          "last_modified"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "generated_at": {
      "type": "string"
    },
    "network_mode": {
      "enum": [
        "disabled",
        "manual_enabled"
      ]
    },
    "object_type": {
      "const": "usda_plants_live_fetch_receipt"
    },
    "plan_ref": {
      "type": "string"
    },
    "quarantine_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "reason_codes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "receipt_hash": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "receipt_id": {
      "pattern": "^kfm\\.",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "snapshot_date": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": "string"
    },
    "source_id": {
      "const": "usda_plants"
    },
    "source_uri": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pass",
        "fail",
        "quarantined"
      ]
    }
  },
  "required": [
    "schema_version",
    "object_type",
    "receipt_id",
    "domain",
    "source_id",
    "source_uri",
    "snapshot_date",
    "generated_at",
    "network_mode",
    "ci",
    "plan_ref",
    "downloaded_files",
    "status",
    "reason_codes",
    "quarantine_refs",
    "receipt_hash"
  ],
  "type": "object"
}
