{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "watch_state_id",
    "domain",
    "source_id",
    "source_uri",
    "last_observed_at",
    "last_snapshot_date",
    "last_observation_ref",
    "last_alert_ref",
    "resources",
    "state_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "object_type": {
      "const": "usda_plants_watch_state"
    },
    "watch_state_id": {
      "type": "string"
    },
    "domain": {
      "const": "flora"
    },
    "source_id": {
      "const": "usda_plants"
    },
    "source_uri": {
      "type": "string",
      "format": "uri"
    },
    "last_observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_snapshot_date": {
      "type": "string",
      "format": "date"
    },
    "last_observation_ref": {
      "type": "string"
    },
    "last_alert_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "url",
          "etag",
          "last_modified",
          "content_length",
          "sha256",
          "status"
        ],
        "properties": {
          "role": {
            "enum": [
              "checklist",
              "state_distribution",
              "county_distribution",
              "unknown"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "etag": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_modified": {
            "type": [
              "string",
              "null"
            ]
          },
          "content_length": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "status": {
            "enum": [
              "observed",
              "missing",
              "failed",
              "skipped"
            ]
          }
        }
      }
    },
    "state_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
