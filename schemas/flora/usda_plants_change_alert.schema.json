{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "alert_id",
    "domain",
    "source_id",
    "source_uri",
    "generated_at",
    "severity",
    "requires_human_review",
    "observation_ref",
    "previous_watch_state_ref",
    "current_watch_state_ref",
    "findings",
    "recommended_actions",
    "publication_blocked",
    "promotion_blocked",
    "status",
    "reason_codes",
    "alert_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "object_type": {
      "const": "usda_plants_change_alert"
    },
    "alert_id": {
      "type": "string"
    },
    "domain": {
      "const": "flora"
    },
    "source_id": {
      "const": "usda_plants"
    },
    "source_uri": {
      "type": "string",
      "format": "uri"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "severity": {
      "enum": [
        "none",
        "info",
        "warning",
        "critical"
      ]
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "observation_ref": {
      "type": "string"
    },
    "previous_watch_state_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "current_watch_state_ref": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publication_blocked": {
      "const": true
    },
    "promotion_blocked": {
      "const": true
    },
    "status": {
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "alert_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
