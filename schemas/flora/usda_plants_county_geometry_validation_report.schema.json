{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "domain": {
      "const": "flora"
    },
    "generated_at": {
      "format": "date-time",
      "type": "string"
    },
    "object_type": {
      "const": "usda_plants_county_geometry_validation_report"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "snapshot_date": {
      "format": "date",
      "type": "string"
    },
    "source_id": {
      "const": "usda_plants"
    },
    "validation_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "object_type",
    "domain",
    "source_id",
    "snapshot_date",
    "generated_at",
    "validation_hash"
  ],
  "type": "object"
}
