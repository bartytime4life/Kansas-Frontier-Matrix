{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "observation_id",
    "domain",
    "source_id",
    "source_uri",
    "generated_at",
    "mode",
    "network_mode",
    "ci",
    "publishes",
    "promotes",
    "creates_pr",
    "downloads_raw",
    "resources",
    "change_summary",
    "status",
    "reason_codes",
    "observation_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "object_type": {
      "const": "usda_plants_scheduled_observation"
    },
    "observation_id": {
      "type": "string"
    },
    "domain": {
      "const": "flora"
    },
    "source_id": {
      "const": "usda_plants"
    },
    "source_uri": {
      "type": "string",
      "format": "uri"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "enum": [
        "scheduled_observe_only",
        "scheduled_mock"
      ]
    },
    "network_mode": {
      "enum": [
        "disabled",
        "scheduled_observation"
      ]
    },
    "ci": {
      "type": "boolean"
    },
    "publishes": {
      "const": false
    },
    "promotes": {
      "const": false
    },
    "creates_pr": {
      "const": false
    },
    "downloads_raw": {
      "type": "boolean"
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "url",
          "status",
          "http_status",
          "etag",
          "last_modified",
          "content_length",
          "sha256",
          "reason_codes"
        ],
        "properties": {
          "role": {
            "enum": [
              "checklist",
              "state_distribution",
              "county_distribution",
              "unknown"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "status": {
            "enum": [
              "observed",
              "missing",
              "failed",
              "skipped"
            ]
          },
          "http_status": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 100,
            "maximum": 599
          },
          "etag": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_modified": {
            "type": [
              "string",
              "null"
            ]
          },
          "content_length": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "change_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changed",
        "added",
        "removed",
        "changed_resources",
        "failed_resources"
      ],
      "properties": {
        "changed": {
          "type": "boolean"
        },
        "added": {
          "type": "integer",
          "minimum": 0
        },
        "removed": {
          "type": "integer",
          "minimum": 0
        },
        "changed_resources": {
          "type": "integer",
          "minimum": 0
        },
        "failed_resources": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "status": {
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "observation_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
