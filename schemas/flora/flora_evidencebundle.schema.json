{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schema/flora/flora_evidencebundle.schema.json",
  "title": "KFM Flora EvidenceBundle",
  "description": "EvidenceBundle schema for Kansas flora ingestion outputs. Designed for Darwin Core-aligned plant occurrence evidence with mandatory attribution, provenance, catalog closure, and fail-closed validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "evidence_bundle_id",
    "domain",
    "candidate_id",
    "spec_hash",
    "status",
    "decision",
    "generated_at",
    "source",
    "harvest",
    "rights",
    "records",
    "provenance",
    "catalog_refs",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "object_type": {
      "type": "string",
      "const": "flora_evidencebundle"
    },
    "evidence_bundle_id": {
      "type": "string",
      "pattern": "^kfm\\.evidence\\.flora\\.[A-Za-z0-9._:-]+$"
    },
    "domain": {
      "type": "string",
      "const": "flora"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "generated",
        "validated",
        "cataloged",
        "promoted",
        "quarantined",
        "withdrawn",
        "superseded"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "cite",
        "abstain",
        "review_required"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_type",
        "source_name",
        "source_descriptor_ref"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": [
            "ipt_dwca",
            "gbif_api",
            "gbif_download",
            "idigbio_api",
            "usda_plants_bulk",
            "manual_fixture",
            "other"
          ]
        },
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_descriptor_ref": {
          "type": "string",
          "minLength": 1
        },
        "endpoint": {
          "type": "string"
        },
        "dataset_doi": {
          "type": "string"
        },
        "dataset_id": {
          "type": "string"
        },
        "dataset_version": {
          "type": "string"
        }
      }
    },
    "harvest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "harvest_id",
        "harvest_date",
        "method"
      ],
      "properties": {
        "harvest_id": {
          "type": "string",
          "minLength": 1
        },
        "harvest_date": {
          "type": "string",
          "format": "date-time"
        },
        "method": {
          "type": "string",
          "enum": [
            "dwca_archive",
            "api_delta",
            "api_snapshot",
            "bulk_snapshot",
            "fixture"
          ]
        },
        "etag": {
          "type": "string"
        },
        "last_modified": {
          "type": "string"
        },
        "modified_since": {
          "type": "string",
          "format": "date-time"
        },
        "archive_checksum": {
          "type": "string"
        }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "license",
        "rightsHolder",
        "datasetID",
        "policy_label"
      ],
      "properties": {
        "license": {
          "type": "string",
          "minLength": 1
        },
        "rightsHolder": {
          "type": "string",
          "minLength": 1
        },
        "datasetID": {
          "type": "string",
          "minLength": 1
        },
        "policy_label": {
          "type": "string",
          "enum": [
            "public",
            "restricted",
            "internal",
            "needs_review"
          ]
        },
        "attribution": {
          "type": "string"
        }
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/flora_record"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "validator",
        "lineage_refs"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "dwca_ingest",
            "api_ingest",
            "bulk_ingest",
            "fixture_ingest"
          ]
        },
        "validator": {
          "type": "string",
          "minLength": 1
        },
        "lineage_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "receipt_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prior_spec_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "catalog_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dcat",
        "stac",
        "prov"
      ],
      "properties": {
        "dcat": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stac": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prov": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "validated_at",
        "result",
        "reason_codes"
      ],
      "properties": {
        "validator_id": {
          "type": "string",
          "minLength": 1
        },
        "validated_at": {
          "type": "string",
          "format": "date-time"
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "warning",
            "not_run"
          ]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sensitivity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contains_sensitive_taxa": {
          "type": "boolean"
        },
        "location_generalized": {
          "type": "boolean"
        },
        "redaction_receipt_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "flora_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "scientificName",
        "basisOfRecord",
        "decimalLatitude",
        "decimalLongitude",
        "eventDate",
        "institutionCode",
        "catalogNumber",
        "license",
        "rightsHolder",
        "datasetID"
      ],
      "properties": {
        "record_id": {
          "type": "string",
          "minLength": 1
        },
        "occurrenceID": {
          "type": "string"
        },
        "scientificName": {
          "type": "string",
          "minLength": 1
        },
        "taxonID": {
          "type": "string"
        },
        "acceptedNameUsage": {
          "type": "string"
        },
        "basisOfRecord": {
          "type": "string",
          "enum": [
            "PreservedSpecimen",
            "HumanObservation",
            "MachineObservation",
            "MaterialSample",
            "Occurrence",
            "LivingSpecimen",
            "Other"
          ]
        },
        "decimalLatitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "decimalLongitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "coordinateUncertaintyInMeters": {
          "type": "number",
          "minimum": 0
        },
        "eventDate": {
          "type": "string",
          "minLength": 1
        },
        "year": {
          "type": "integer",
          "minimum": 1600,
          "maximum": 2200
        },
        "stateProvince": {
          "type": "string"
        },
        "county": {
          "type": "string"
        },
        "locality": {
          "type": "string"
        },
        "institutionCode": {
          "type": "string",
          "minLength": 1
        },
        "collectionCode": {
          "type": "string"
        },
        "catalogNumber": {
          "type": "string",
          "minLength": 1
        },
        "recordedBy": {
          "type": "string"
        },
        "identifiedBy": {
          "type": "string"
        },
        "dateIdentified": {
          "type": "string"
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "rightsHolder": {
          "type": "string",
          "minLength": 1
        },
        "datasetID": {
          "type": "string",
          "minLength": 1
        },
        "source_record_ref": {
          "type": "string"
        },
        "dedupe_key": {
          "type": "string",
          "description": "Recommended canonical key: institutionCode + catalogNumber + eventDate."
        },
        "policy_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
