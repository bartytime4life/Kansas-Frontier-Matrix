{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","object_type","review_decision_id","domain","source_id","snapshot_date","generated_at","reviewer","review_scope","decision","decision_reason_codes","conditions","blocked_actions","publication_state","promotion_state","status","decision_hash"],
  "properties": {
    "schema_version": {"const": "1.0.0"},"object_type": {"const": "usda_plants_review_decision"},"review_decision_id": {"type": "string"},"domain": {"const": "flora"},"source_id": {"const": "usda_plants"},"snapshot_date": {"type": "string","format": "date"},"generated_at": {"type": "string","format": "date-time"},
    "reviewer": {"type": "object","additionalProperties": false,"required": ["reviewer_id","reviewer_type","attestation"],"properties": {"reviewer_id": {"type": "string"},"reviewer_type": {"enum": ["human","system"]},"attestation": {"type": "string"}}},
    "review_scope": {"type": "object","additionalProperties": false,"required": ["release_candidate_ref","change_alert_ref","reviewer_queue_ref","pr_handoff_ref"],"properties": {"release_candidate_ref": {"type": "string"},"change_alert_ref": {"type": "string"},"reviewer_queue_ref": {"type": "string"},"pr_handoff_ref": {"type": "string"}}},
    "decision": {"enum": ["approved_for_preflight","rejected","needs_changes","abstain"]},"decision_reason_codes": {"type": "array","items": {"type": "string"}},"conditions": {"type": "array","items": {"type": "string"}},"blocked_actions": {"type": "array","items": {"type": "string"}},"publication_state": {"const": "not_published"},"promotion_state": {"const": "not_promoted"},"status": {"enum": ["pass","fail"]},"decision_hash": {"type": "string","pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
