```json
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schema/ecology/kfm_eco_index.schema.json",
  "title": "KFM Ecology Cross-Domain Join Index",
  "description": "Proposed schema for deterministic ecological join-index rows used to connect vegetation, soil, hydrology, flora, fauna, habitat, land-cover, air-quality, catalog, and runtime evidence references.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "index_id",
    "geom_id",
    "time_bucket",
    "spec_hash",
    "domains",
    "evidence_refs",
    "status"
  ],
  "properties": {
    "index_id": {
      "type": "string",
      "pattern": "^kfm\\.eco_index\\.[a-z0-9_.:-]+$"
    },
    "geom_id": {
      "type": "string",
      "minLength": 1
    },
    "geometry_type": {
      "type": "string",
      "enum": [
        "county",
        "grid",
        "hex",
        "huc12",
        "reach",
        "station_buffer",
        "custom"
      ]
    },
    "time_bucket": {
      "type": "string",
      "minLength": 1
    },
    "time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "bucket"],
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "bucket": {
          "type": "string",
          "enum": [
            "daily",
            "monthly",
            "seasonal",
            "annual",
            "multi_year",
            "event"
          ]
        }
      }
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "flora",
          "fauna",
          "habitat",
          "soil",
          "air",
          "vegetation",
          "landcover",
          "hydrology"
        ]
      }
    },
    "join_keys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "taxon_id": {
          "type": "string"
        },
        "obs_id": {
          "type": "string"
        },
        "soil_id": {
          "type": "string"
        },
        "landcover_class": {
          "type": "string"
        },
        "watershed_id": {
          "type": "string"
        },
        "reach_id": {
          "type": "string"
        },
        "station_id": {
          "type": "string"
        },
        "layer_id": {
          "type": "string"
        }
      }
    },
    "catalog_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dcat": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stac": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prov": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["domain", "evidence_ref"],
        "properties": {
          "domain": {
            "type": "string",
            "enum": [
              "flora",
              "fauna",
              "habitat",
              "soil",
              "air",
              "vegetation",
              "landcover",
              "hydrology"
            ]
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          },
          "receipt_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proof_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spatial_precision": {
          "type": "string"
        },
        "temporal_precision": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "generalized",
        "restricted",
        "review_required"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "valid",
        "partial",
        "quarantined",
        "deprecated"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "geometry_type": {
            "const": "huc12"
          }
        }
      },
      "then": {
        "properties": {
          "join_keys": {
            "required": ["watershed_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "domains": {
            "contains": {
              "const": "flora"
            }
          }
        }
      },
      "then": {
        "properties": {
          "join_keys": {
            "anyOf": [
              {
                "required": ["taxon_id"]
              },
              {
                "required": ["obs_id"]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "domains": {
            "contains": {
              "const": "fauna"
            }
          }
        }
      },
      "then": {
        "properties": {
          "join_keys": {
            "anyOf": [
              {
                "required": ["taxon_id"]
              },
              {
                "required": ["obs_id"]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "domains": {
            "contains": {
              "const": "soil"
            }
          }
        }
      },
      "then": {
        "properties": {
          "join_keys": {
            "anyOf": [
              {
                "required": ["soil_id"]
              },
              {
                "required": ["station_id"]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "domains": {
            "contains": {
              "const": "hydrology"
            }
          }
        }
      },
      "then": {
        "properties": {
          "join_keys": {
            "anyOf": [
              {
                "required": ["watershed_id"]
              },
              {
                "required": ["reach_id"]
              },
              {
                "required": ["station_id"]
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "domains": {
            "contains": {
              "const": "vegetation"
            }
          }
        }
      },
      "then": {
        "properties": {
          "join_keys": {
            "anyOf": [
              {
                "required": ["layer_id"]
              },
              {
                "required": ["landcover_class"]
              }
            ]
          }
        }
      }
    }
  ]
}
```
