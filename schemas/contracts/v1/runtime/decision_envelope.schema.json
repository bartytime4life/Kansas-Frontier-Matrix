{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kfm.local/contracts/v1/runtime/decision_envelope.schema.json",
  "title": "decision_envelope",
  "type": "object",
  "description": "KFM contract for decision_envelope.",
  "x-kfm": {
    "contract_doc": "contracts/runtime/decision_envelope.md",
    "fixtures_root": "fixtures/contracts/v1/runtime/decision_envelope/",
    "validator": "tools/validators/validate_decision_envelope.py",
    "policy": "policy/runtime/",
    "status": "PROPOSED"
  },
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:.-]*$"
    },
    "id": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "ANSWER",
        "ABSTAIN",
        "DENY",
        "ERROR"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "ANSWER",
        "ABSTAIN",
        "DENY",
        "ERROR"
      ]
    },
    "policy_family": {
      "type": "string",
      "enum": [
        "promotion",
        "access",
        "render",
        "capability",
        "consent",
        "sensitivity"
      ]
    },
    "reason_code": {
      "type": "string"
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "spec_hash": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "decision_id",
    "outcome",
    "policy_family",
    "reasons",
    "obligations",
    "evaluated_at"
  ],
  "additionalProperties": false
}
