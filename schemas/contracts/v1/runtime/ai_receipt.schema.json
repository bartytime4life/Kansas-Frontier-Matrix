{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kfm.local/contracts/v1/runtime/ai_receipt.schema.json",
  "title": "ai_receipt",
  "type": "object",
  "description": "KFM contract for ai_receipt.",
  "x-kfm": {
    "contract_doc": "contracts/runtime/ai_receipt.md",
    "fixtures_root": "fixtures/runtime/ai_receipt/",
    "validator": "tools/validators/runtime/validate_ai_receipt.py",
    "policy": "policy/runtime/",
    "status": "PROPOSED"
  },
  "properties": {
    "id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "adapter": {
      "type": "string"
    },
    "model_ref": {
      "type": "string"
    },
    "inputs_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "outputs_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "policy_decision_ref": {
      "type": "string"
    },
    "citation_validation_ref": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "ANSWER",
        "ABSTAIN",
        "DENY",
        "ERROR"
      ]
    }
  },
  "required": [
    "id",
    "run_id",
    "adapter",
    "model_ref",
    "inputs_digest",
    "outputs_digest",
    "policy_decision_ref",
    "citation_validation_ref",
    "outcome"
  ],
  "additionalProperties": false
}
