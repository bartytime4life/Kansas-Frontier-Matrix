{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.example/schemas/contracts/v1/common/run_receipt.schema.json",
  "title": "RunReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schema_version", "run_receipt_id", "spec_hash", "generated_at"],
  "properties": {
    "kind": { "const": "RunReceipt" },
    "schema_version": { "const": "v1" },
    "run_receipt_id": { "type": "string", "minLength": 1 },
    "spec_hash": { "type": "string", "minLength": 8 },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
