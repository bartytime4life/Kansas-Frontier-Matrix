{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kfm.local/contracts/v1/policy/policy_decision.schema.json",
  "title": "policy_decision",
  "type": "object",
  "description": "KFM contract for policy_decision.",
  "x-kfm": {
    "contract_doc": "contracts/policy/policy_decision.md",
    "fixtures_root": "fixtures/policy/policy_decision/",
    "validator": "tools/validators/policy/validate_policy_decision.py",
    "policy": "policy/policy/",
    "status": "PROPOSED"
  },
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "ANSWER",
        "ABSTAIN",
        "DENY",
        "ERROR"
      ]
    },
    "policy_family": {
      "type": "string",
      "enum": [
        "promotion",
        "access",
        "render",
        "capability",
        "consent",
        "sensitivity"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "decision_id",
    "outcome",
    "policy_family",
    "reasons",
    "obligations",
    "evaluated_at"
  ],
  "additionalProperties": false
}
