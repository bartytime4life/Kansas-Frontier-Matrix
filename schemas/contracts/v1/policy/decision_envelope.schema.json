{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.example/schemas/contracts/v1/policy/decision_envelope.schema.json",
  "title": "DecisionEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "decision_id",
    "outcome",
    "reason_codes",
    "obligations",
    "policy_version",
    "audit_ref"
  ],
  "properties": {
    "kind": { "const": "DecisionEnvelope" },
    "schema_version": { "const": "v1" },
    "decision_id": { "type": "string", "minLength": 1 },
    "outcome": { "type": "string", "enum": ["ALLOW", "DENY", "ABSTAIN", "ERROR"] },
    "reason_codes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
    "obligations": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
    "policy_version": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 }
  }
}
