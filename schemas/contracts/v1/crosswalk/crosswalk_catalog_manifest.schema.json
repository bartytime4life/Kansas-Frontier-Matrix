{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schema/contracts/v1/crosswalk/crosswalk_catalog_manifest.schema.json",
  "title": "KFM Crosswalk Catalog Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_type",
    "run_id",
    "run_receipt_id",
    "watcher",
    "algorithm_version",
    "record_count",
    "source_snapshot_ids",
    "bbox_epsg_5070",
    "catalog_outputs",
    "publication",
    "created_at"
  ],
  "properties": {
    "object_type": {
      "const": "crosswalk_catalog_manifest"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "watcher": {
      "const": "hydrology_huc12_admin_crosswalk_watch"
    },
    "algorithm_version": {
      "type": "string",
      "minLength": 1
    },
    "record_count": {
      "type": "integer",
      "minimum": 1
    },
    "source_snapshot_ids": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "bbox_epsg_5070": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "catalog_outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stac", "dcat", "prov"],
      "properties": {
        "stac": { "type": "string", "minLength": 1 },
        "dcat": { "type": "string", "minLength": 1 },
        "prov": { "type": "string", "minLength": 1 }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["published", "state", "reason"],
      "properties": {
        "published": { "const": false },
        "state": { "const": "candidate_no_publish" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
