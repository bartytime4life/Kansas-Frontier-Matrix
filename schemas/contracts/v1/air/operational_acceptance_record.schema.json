{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "acceptance_conditions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "acceptance_decision": {
      "enum": [
        "accept_fixture_operation",
        "accept_candidate_operation",
        "request_more_evidence",
        "block_operation",
        "production_acceptance_blocked"
      ]
    },
    "acceptance_id": {
      "type": "string"
    },
    "accepted_environment": {
      "enum": [
        "local_fixture",
        "staging_candidate",
        "production_proposed",
        "production"
      ]
    },
    "as_of": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "cutover_observation_ref": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "evidence_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "fixture_backed": {
      "type": "boolean"
    },
    "post_deploy_gate_evaluation_ref": {
      "type": "string"
    },
    "release_ledger_manifest_ref": {
      "type": "string"
    },
    "required_followups": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_version": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "signature_type": {
      "enum": [
        "fixture_signature",
        "cosign",
        "gpg",
        "sigstore"
      ]
    },
    "status": {
      "enum": [
        "fixture_accepted",
        "candidate_accepted",
        "needs_review",
        "blocked",
        "production_blocked"
      ]
    },
    "subject_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "acceptance_id",
    "domain",
    "created_at",
    "as_of",
    "cutover_observation_ref",
    "post_deploy_gate_evaluation_ref",
    "release_ledger_manifest_ref",
    "accepted_environment",
    "acceptance_decision",
    "acceptance_conditions",
    "required_followups",
    "evidence_refs",
    "signature",
    "signature_type",
    "fixture_backed",
    "status"
  ],
  "type": "object"
}
