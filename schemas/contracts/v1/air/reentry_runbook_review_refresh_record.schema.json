{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "runbook_review_id",
    "domain",
    "created_at",
    "as_of",
    "continuous_assurance_refresh_plan_ref",
    "runbook_activation_refresh_candidate_ref",
    "operational_handoff_refresh_package_ref",
    "review_scope",
    "checks",
    "findings",
    "recommended_updates",
    "forbidden_actions",
    "safety_checks",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "runbook_review_id": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "created_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "continuous_assurance_refresh_plan_ref": {
      "type": "string"
    },
    "runbook_activation_refresh_candidate_ref": {
      "type": "string"
    },
    "operational_handoff_refresh_package_ref": {
      "type": "string"
    },
    "review_scope": {
      "type": "string"
    },
    "checks": {
      "type": "string"
    },
    "findings": {
      "type": "string"
    },
    "recommended_updates": {
      "type": "string"
    },
    "forbidden_actions": {
      "type": "string"
    },
    "safety_checks": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "fixture_review_passed",
        "candidate_review_passed",
        "needs_update",
        "needs_review",
        "blocked",
        "production_review_blocked"
      ]
    }
  }
}
