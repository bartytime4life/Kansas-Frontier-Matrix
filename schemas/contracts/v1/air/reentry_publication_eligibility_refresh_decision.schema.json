{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "decision_id": {
      "type": "string"
    },
    "decided_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "publication_boundary_refresh_review_ref": {
      "type": "string"
    },
    "gate_d_refresh_attestation_ref": {
      "type": "string"
    },
    "aqs_reconciliation_refresh_checkpoint_ref": {
      "type": "string"
    },
    "release_candidate_refresh_decision_ref": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "approved_for_fixture_publication_candidate_refresh",
        "approved_for_publication_candidate_refresh",
        "request_more_evidence",
        "blocked",
        "production_publication_blocked"
      ]
    },
    "gates": {
      "type": "object"
    },
    "required_followups": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signature": {
      "type": "string"
    },
    "signature_type": {
      "enum": [
        "fixture_signature",
        "cosign",
        "gpg",
        "sigstore"
      ]
    },
    "fixture_backed": {
      "type": "string"
    },
    "status": {
      "enum": [
        "fixture_candidate_ready",
        "candidate_ready",
        "needs_review",
        "blocked",
        "production_blocked"
      ]
    },
    "checks": {
      "type": "object"
    },
    "safety_checks": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hard_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "differences": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "source_rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "aqs_validated_window": {
      "type": "object",
      "properties": {
        "averaging_window": {
          "type": "string"
        },
        "pm25_units": {
          "const": "ug_m3"
        },
        "nowcast_semantics": {
          "type": "string"
        }
      },
      "required": [
        "averaging_window",
        "pm25_units",
        "nowcast_semantics"
      ]
    }
  },
  "required": [
    "schema_version",
    "domain",
    "decision_id",
    "decided_at",
    "as_of",
    "publication_boundary_refresh_review_ref",
    "gate_d_refresh_attestation_ref",
    "aqs_reconciliation_refresh_checkpoint_ref",
    "release_candidate_refresh_decision_ref",
    "decision",
    "gates",
    "required_followups",
    "evidence_refs",
    "signature",
    "signature_type",
    "fixture_backed",
    "status"
  ]
}
