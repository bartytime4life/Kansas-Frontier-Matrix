{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "readiness_plan_id",
    "domain",
    "created_at",
    "as_of",
    "deployment_environment_refresh_candidate_ref",
    "client_delivery_refresh_manifest_ref",
    "client_delivery_refresh_decision_ref",
    "client_delivery_refresh_postcheck_report_ref",
    "client_delivery_refresh_audit_report_ref",
    "client_delivery_refresh_ledger_manifest_ref",
    "static_hosting_manifest_refresh_candidate_ref",
    "client_compatibility_refresh_report_ref",
    "planned_readiness_artifacts",
    "preflight_checks",
    "postflight_checks",
    "rollback_refresh_plan_ref",
    "cache_invalidation_refresh_plan_ref",
    "synthetic_probe_refresh_spec_ref",
    "non_mutation_guarantees",
    "forbidden_actions",
    "safety_checks",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "readiness_plan_id": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "created_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "deployment_environment_refresh_candidate_ref": {
      "type": "string"
    },
    "client_delivery_refresh_manifest_ref": {
      "type": "string"
    },
    "client_delivery_refresh_decision_ref": {
      "type": "string"
    },
    "client_delivery_refresh_postcheck_report_ref": {
      "type": "string"
    },
    "client_delivery_refresh_audit_report_ref": {
      "type": "string"
    },
    "client_delivery_refresh_ledger_manifest_ref": {
      "type": "string"
    },
    "static_hosting_manifest_refresh_candidate_ref": {
      "type": "string"
    },
    "client_compatibility_refresh_report_ref": {
      "type": "string"
    },
    "planned_readiness_artifacts": {
      "type": "string"
    },
    "preflight_checks": {
      "type": "string"
    },
    "postflight_checks": {
      "type": "string"
    },
    "rollback_refresh_plan_ref": {
      "type": "string"
    },
    "cache_invalidation_refresh_plan_ref": {
      "type": "string"
    },
    "synthetic_probe_refresh_spec_ref": {
      "type": "string"
    },
    "non_mutation_guarantees": {
      "type": "string"
    },
    "forbidden_actions": {
      "type": "string"
    },
    "safety_checks": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "fixture_readiness_refresh_plan",
        "candidate_readiness_refresh_plan",
        "needs_review",
        "blocked",
        "production_readiness_refresh_blocked"
      ]
    }
  }
}
