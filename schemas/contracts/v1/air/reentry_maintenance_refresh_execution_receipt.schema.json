{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "actor": {
      "type": "string"
    },
    "artifact_refs": {
      "items": {},
      "type": "array"
    },
    "as_of": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "execution_mode": {
      "enum": [
        "dry_run",
        "fixture_refresh_simulation",
        "manual_refresh_review_prepared",
        "production_execution_blocked"
      ]
    },
    "hashes": {
      "items": {},
      "type": "array"
    },
    "maintenance_receipt_id": {
      "type": "string"
    },
    "maintenance_refresh_authorization_ref": {
      "type": "string"
    },
    "maintenance_refresh_execution_plan_ref": {
      "type": "string"
    },
    "maintenance_refresh_fixture_simulation_ref": {
      "type": "string"
    },
    "result": {
      "enum": [
        "pass",
        "warn",
        "deny",
        "blocked"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "fixture_receipt",
        "candidate_receipt",
        "needs_review",
        "blocked",
        "production_receipt_blocked"
      ]
    },
    "steps_observed": {
      "items": {},
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "maintenance_receipt_id",
    "domain",
    "created_at",
    "as_of",
    "execution_mode",
    "maintenance_refresh_authorization_ref",
    "maintenance_refresh_execution_plan_ref",
    "maintenance_refresh_fixture_simulation_ref",
    "actor",
    "steps_observed",
    "artifact_refs",
    "hashes",
    "result",
    "status"
  ],
  "type": "object"
}
