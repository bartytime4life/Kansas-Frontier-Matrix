    "static_hosting_manifest_ref",
    "readiness_report_ref",
    "synthetic_probe_report_ref",
    "checks",
    "hash_checks",
    "etag_checks",
    "route_checks",
    "secret_checks",
    "path_safety_checks",
    "semantic_checks",
    "result"
  ],
  "type": "object"
}
