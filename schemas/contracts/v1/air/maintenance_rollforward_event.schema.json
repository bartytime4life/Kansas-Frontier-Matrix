{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "actor": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    },
    "as_of": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    },
    "created_at": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    },
    "details": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "event_id": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    },
    "event_type": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    },
    "evidence_refs": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    },
    "result": {
      "enum": [
        "pass",
        "warn",
        "deny",
        "blocked"
      ]
    },
    "schema_version": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    },
    "subject_refs": {
      "type": [
        "string",
        "boolean",
        "array",
        "object"
      ]
    }
  },
  "required": [
    "schema_version",
    "event_id",
    "domain",
    "event_type",
    "created_at",
    "as_of",
    "actor",
    "subject_refs",
    "evidence_refs",
    "result",
    "details"
  ],
  "type": "object"
}
