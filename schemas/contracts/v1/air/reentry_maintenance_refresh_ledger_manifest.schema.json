{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "as_of": {
      "type": "string"
    },
    "chain_hash": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "entry_refs": {
      "items": {},
      "type": "array"
    },
    "generated_at": {
      "type": "string"
    },
    "head_entry_ref": {
      "type": "string"
    },
    "ledger_id": {
      "type": "string"
    },
    "safety_checks": {
      "items": {},
      "type": "array"
    },
    "schema_version": {
      "type": "string"
    },
    "source_refs": {
      "items": {},
      "type": "array"
    },
    "status": {
      "enum": [
        "fixture_maintenance_refresh_ledger",
        "candidate_maintenance_refresh_ledger",
        "needs_review",
        "blocked",
        "production_ledger_blocked"
      ]
    }
  },
  "required": [
    "schema_version",
    "ledger_id",
    "domain",
    "generated_at",
    "as_of",
    "entry_refs",
    "head_entry_ref",
    "chain_hash",
    "source_refs",
    "safety_checks",
    "status"
