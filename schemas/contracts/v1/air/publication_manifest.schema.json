{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://kfm.dev/schemas/contracts/v1/air/publication_manifest.schema.json","title":"KFM Air PublicationManifest","type":"object","additionalProperties":false,"required":["schema_version","publication_id","domain","release_manifest_ref","promotion_decision_ref","evidence_bundle_ref","run_receipt_ref","attestation_ref","aqs_reconciliation_ref","published_artifacts","public_boundary_checks","published_at","status"],"properties":{"schema_version":{"type":"string","const":"v1"},"publication_id":{"type":"string","minLength":1},"domain":{"type":"string","const":"atmosphere.air"},"release_manifest_ref":{"type":"string","minLength":1},"promotion_decision_ref":{"type":"string","minLength":1},"evidence_bundle_ref":{"type":"string","minLength":1},"run_receipt_ref":{"type":"string","minLength":1},"attestation_ref":{"type":"string"},"aqs_reconciliation_ref":{"type":"string"},"published_artifacts":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["artifact_type","path","sha256","source_ref"],"properties":{"artifact_type":{"type":"string","minLength":1},"path":{"type":"string","minLength":1},"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"},"source_ref":{"type":"string","minLength":1}}}},"public_boundary_checks":{"type":"object","additionalProperties":true,"required":["no_raw_work_quarantine_refs"],"properties":{"no_raw_work_quarantine_refs":{"const":true}}},"published_at":{"type":"string","format":"date-time"},"status":{"type":"string","enum":["publication_candidate","published_fixture_blocked","published","retracted"]}}}
