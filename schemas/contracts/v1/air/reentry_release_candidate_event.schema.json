{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "domain",
    "event_type",
    "created_at",
    "as_of",
    "actor",
    "subject_refs",
    "evidence_refs",
    "result",
    "details"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "event_type": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "subject_refs": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "string"
    },
    "result": {
      "type": "string"
    },
    "details": {
      "type": "string"
    }
  }
}
