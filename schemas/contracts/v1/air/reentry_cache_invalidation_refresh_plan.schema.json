{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "cache_refresh_plan_id",
    "domain",
    "created_at",
    "as_of",
    "client_cache_manifest_refresh_candidate_ref",
    "client_delta_cursor_refresh_candidate_refs",
    "planned_invalidations",
    "forbidden_actions",
    "safety_checks",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "cache_refresh_plan_id": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "created_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "client_cache_manifest_refresh_candidate_ref": {
      "type": "string"
    },
    "client_delta_cursor_refresh_candidate_refs": {
      "type": "string"
    },
    "planned_invalidations": {
      "type": "string"
    },
    "forbidden_actions": {
      "type": "string"
    },
    "safety_checks": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "fixture_cache_invalidation_refresh_plan",
        "candidate_cache_invalidation_refresh_plan",
        "needs_review",
        "blocked",
        "production_cache_invalidation_refresh_blocked"
      ]
    }
  }
}
