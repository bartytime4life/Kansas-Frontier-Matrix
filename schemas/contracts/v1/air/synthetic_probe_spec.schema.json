  "additionalProperties": true,
  "properties": {
    "domain": {
      "const": "atmosphere.air"
    },
    "status": {
      "enum": [
        "fixture_probe_spec",
        "candidate_probe_spec",
        "production_probe_proposed_blocked",
        "blocked"
      ]
