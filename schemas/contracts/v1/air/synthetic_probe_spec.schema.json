  "required": [
    "schema_version",
    "probe_spec_id",
    "domain",
    "created_at",
    "as_of",
    "client_delivery_manifest_ref",
    "routes_under_test",
    "expected_responses",
    "fixtures",
    "safety_checks",
    "status"
  ],
  "type": "object"
}
