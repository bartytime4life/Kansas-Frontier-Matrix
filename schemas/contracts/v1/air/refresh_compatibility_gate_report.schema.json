{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "gate_report_id",
    "domain",
    "generated_at",
    "as_of",
    "candidate_reentry_package_ref",
    "candidate_read_model_refresh_ref",
    "client_delivery_refresh_manifest_ref",
    "sunset_delta_candidate_ref",
    "checks",
    "hash_checks",
    "etag_checks",
    "route_checks",
    "delta_checks",
    "baseline_checks",
    "path_safety_checks",
    "semantic_checks",
    "hard_failures",
    "warnings",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "result": {
      "type": "string",
      "enum": [
        "pass_fixture",
        "pass_candidate",
        "warn",
        "deny",
        "blocked"
      ]
    }
  }
}
