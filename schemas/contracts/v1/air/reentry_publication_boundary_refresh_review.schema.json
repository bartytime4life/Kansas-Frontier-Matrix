{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "review_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "release_candidate_refresh_package_ref": {
      "type": "string"
    },
    "qa_revalidation_refresh_report_ref": {
      "type": "string"
    },
    "release_evidence_bundle_refresh_ref": {
      "type": "string"
    },
    "catalog_refresh_candidate_manifest_ref": {
      "type": "string"
    },
    "release_manifest_refresh_candidate_ref": {
      "type": "string"
    },
    "release_candidate_refresh_decision_ref": {
      "type": "string"
    },
    "release_candidate_refresh_lineage_bridge_ref": {
      "type": "string"
    },
    "release_candidate_refresh_manifest_ref": {
      "type": "string"
    },
    "release_candidate_refresh_postcheck_report_ref": {
      "type": "string"
    },
    "release_candidate_refresh_audit_report_ref": {
      "type": "string"
    },
    "release_candidate_refresh_ledger_manifest_ref": {
      "type": "string"
    },
    "gate_d_refresh_attestation_ref": {
      "type": "string"
    },
    "aqs_reconciliation_refresh_checkpoint_ref": {
      "type": "string"
    },
    "checks": {
      "type": "object"
    },
    "hard_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "result": {
      "enum": [
        "pass_fixture",
        "pass_candidate",
        "warn",
        "deny",
        "blocked"
      ]
    },
    "gates": {
      "type": "object"
    },
    "safety_checks": {
      "type": "object"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "differences": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "source_rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "aqs_validated_window": {
      "type": "object",
      "properties": {
        "averaging_window": {
          "type": "string"
        },
        "pm25_units": {
          "const": "ug_m3"
        },
        "nowcast_semantics": {
          "type": "string"
        }
      },
      "required": [
        "averaging_window",
        "pm25_units",
        "nowcast_semantics"
      ]
    }
  },
  "required": [
    "schema_version",
    "domain",
    "review_id",
    "generated_at",
    "as_of",
    "release_candidate_refresh_package_ref",
    "qa_revalidation_refresh_report_ref",
    "release_evidence_bundle_refresh_ref",
    "catalog_refresh_candidate_manifest_ref",
    "release_manifest_refresh_candidate_ref",
    "release_candidate_refresh_decision_ref",
    "release_candidate_refresh_lineage_bridge_ref",
    "release_candidate_refresh_manifest_ref",
    "release_candidate_refresh_postcheck_report_ref",
    "release_candidate_refresh_audit_report_ref",
    "release_candidate_refresh_ledger_manifest_ref",
    "gate_d_refresh_attestation_ref",
    "aqs_reconciliation_refresh_checkpoint_ref",
    "checks",
    "hard_failures",
    "warnings",
    "result"
  ]
}
