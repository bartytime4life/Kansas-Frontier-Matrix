{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "reentry_manifest_id",
    "domain",
    "generated_at",
    "as_of",
    "candidate_reentry_package_ref",
    "rollforward_acceptance_record_ref",
    "refreshed_baseline_recertification_ref",
    "refresh_compatibility_gate_report_ref",
    "candidate_reentry_promotion_decision_ref",
    "sunset_review_queue_ref",
    "sunset_review_decision_refs",
    "artifact_refs",
    "next_lifecycle_target",
    "safety_checks",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "next_lifecycle_target": {
      "type": "string",
      "enum": [
        "fixture_candidate_review",
        "candidate_review",
        "release_candidate_reentry_proposed",
        "blocked"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "fixture_reentry_manifest",
        "candidate_reentry_manifest",
        "needs_review",
        "blocked",
        "production_reentry_blocked"
      ]
    }
  }
}
