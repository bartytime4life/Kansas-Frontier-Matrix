{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "checks": {
      "type": "object"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "status": {
      "enum": [
        "green",
        "yellow",
        "red",
        "fixture_only",
        "blocked"
      ]
    }
  },
  "required": [
    "schema_version",
    "health_id",
    "domain",
    "generated_at",
    "as_of",
    "input_refs",
    "checks",
    "counts",
    "warnings",
    "incidents",
    "status"
  ],
  "type": "object"
}
