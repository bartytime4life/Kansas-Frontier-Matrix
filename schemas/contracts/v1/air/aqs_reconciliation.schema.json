{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://kfm.dev/schemas/contracts/v1/air/aqs_reconciliation.schema.json","title":"KFM Air AQS Reconciliation","type":"object","additionalProperties":false,"required":["schema_version","reconciliation_id","domain","qa_summary_ref","evidence_bundle_ref","aqs_validated_window","reconciled_at","method","status","differences","source_rows"],"properties":{"schema_version":{"type":"string","const":"v1"},"reconciliation_id":{"type":"string","minLength":1},"domain":{"type":"string","const":"atmosphere.air"},"qa_summary_ref":{"type":"string","minLength":1},"evidence_bundle_ref":{"type":"string","minLength":1},"aqs_validated_window":{"type":"object","additionalProperties":false,"required":["averaging_window","parameter","units","note"],"properties":{"averaging_window":{"type":"string"},"parameter":{"type":"string","const":"pm25"},"units":{"type":"string","const":"ug_m3"},"note":{"type":"string","pattern":".*NowCast.*operational evidence.*not validated AQS truth.*"}}},"reconciled_at":{"type":"string","format":"date-time"},"method":{"type":"string","minLength":1},"status":{"type":"string","enum":["not_required","pending","reconciled","conflict_detected"]},"differences":{"type":"array","items":{"type":"object"}},"source_rows":{"type":"integer","minimum":0}},"allOf":[{"if":{"properties":{"status":{"const":"reconciled"}}},"then":{"properties":{"aqs_validated_window":{"properties":{"averaging_window":{"const":"24h_validated"}}}}}}]}
