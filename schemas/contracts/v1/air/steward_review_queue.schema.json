{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm/schemas/contracts/v1/air/steward_review_queue.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "queue_id", "domain", "generated_at", "as_of", "input_refs", "items", "summary", "status"],
  "properties": {
    "schema_version": {"type": "string"},
    "queue_id": {"type": "string"},
    "domain": {"const": "atmosphere.air"},
    "generated_at": {"type": "string"},
    "as_of": {"type": "string"},
    "input_refs": {"type": "array", "items": {"type": "string"}},
    "items": {"type": "array", "items": {"$ref": "#/$defs/item"}},
    "summary": {"type": "object"},
    "status": {"enum": ["empty", "needs_review", "blocked", "fixture_only"]}
  },
  "$defs": {"item": {"type": "object", "additionalProperties": false, "required": ["item_id", "priority", "reason", "incident_ref", "retraction_request_ref", "publication_manifest_ref", "affected_artifacts", "evidence_refs", "recommended_action", "review_required_by", "fixture_backed"], "properties": {"item_id": {"type": "string"}, "priority": {"enum": ["info", "low", "medium", "high", "critical"]}, "reason": {"type": "string"}, "incident_ref": {"type": "string"}, "retraction_request_ref": {"type": "string"}, "publication_manifest_ref": {"type": "string"}, "affected_artifacts": {"type": "array", "items": {"type": "object"}}, "evidence_refs": {"type": "array", "items": {"type": "string"}}, "recommended_action": {"type": "string"}, "review_required_by": {"type": "string"}, "fixture_backed": {"type": "boolean"}}}}
}
