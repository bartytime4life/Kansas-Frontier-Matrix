{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "decision_id",
    "domain",
    "decided_at",
    "decided_by",
    "role",
    "subject_refs",
    "decision",
    "rationale",
    "required_actions",
    "signature",
    "signature_type",
    "fixture_backed",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve_fixture_sunset_review",
        "approve_candidate_sunset_review",
        "request_more_evidence",
        "reject_sunset",
        "block_sunset",
        "production_sunset_blocked"
      ]
    },
    "signature_type": {
      "type": "string",
      "enum": [
        "fixture_signature",
        "cosign",
        "gpg",
        "sigstore"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "fixture_decision",
        "candidate_decision",
        "needs_review",
        "blocked",
        "production_blocked"
      ]
    }
  }
}
