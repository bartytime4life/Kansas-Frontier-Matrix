{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "domain": {
      "const": "atmosphere.air"
    },
    "status": {
      "enum": [
        "candidate",
        "needs_steward_review",
        "approved",
        "rejected",
        "tombstone_written"
      ]
    }
  },
  "required": [
    "schema_version",
    "retraction_request_id",
    "domain",
    "created_at",
    "requested_by",
    "incident_ref",
    "publication_manifest_ref",
    "reason",
    "affected_artifacts",
    "evidence_refs",
    "recommended_tombstone",
    "status"
  ],
  "type": "object"
}
