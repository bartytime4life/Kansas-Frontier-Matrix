{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "probe_report_id",
    "domain",
    "generated_at",
    "as_of",
    "synthetic_probe_refresh_spec_ref",
    "client_delivery_refresh_manifest_ref",
    "static_hosting_manifest_refresh_candidate_ref",
    "results",
    "failures",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "probe_report_id": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "generated_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "synthetic_probe_refresh_spec_ref": {
      "type": "string"
    },
    "client_delivery_refresh_manifest_ref": {
      "type": "string"
    },
    "static_hosting_manifest_refresh_candidate_ref": {
      "type": "string"
    },
    "results": {
      "type": "string"
    },
    "failures": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass_fixture",
        "pass_candidate",
        "warn",
        "deny",
        "blocked"
      ]
    }
  }
}
