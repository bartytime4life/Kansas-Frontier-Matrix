{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "actor": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "details": {
      "type": "object"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "enum": [
        "cutover_observation_created",
        "post_deploy_gates_evaluated",
        "release_ledger_written",
        "operational_acceptance_prepared",
        "rollback_decision_prepared",
        "stakeholder_notice_drafted",
        "cutover_blocked"
      ]
    },
    "evidence_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "result": {
      "enum": [
        "pass",
        "warn",
        "deny",
        "blocked"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "subject_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "event_id",
    "domain",
    "event_type",
    "created_at",
    "as_of",
    "actor",
    "subject_refs",
    "evidence_refs",
    "result",
    "details"
  ],
  "type": "object"
}
