    },
    "readiness_report_id": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "generated_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "deployment_readiness_refresh_plan_ref": {
      "type": "string"
    },
    "deployment_environment_refresh_candidate_ref": {
      "type": "string"
    },
    "static_hosting_manifest_refresh_candidate_ref": {
      "type": "string"
    },
    "client_delivery_refresh_manifest_ref": {
      "type": "string"
    },
    "synthetic_probe_refresh_report_ref": {
      "type": "string"
    },
    "cache_invalidation_refresh_plan_ref": {
      "type": "string"
    },
    "deployment_rollback_refresh_plan_ref": {
      "type": "string"
    },
    "checks": {
      "type": "string"
    },
    "hash_checks": {
      "type": "string"
    },
    "etag_checks": {
      "type": "string"
    },
    "route_checks": {
      "type": "string"
    },
    "compatibility_checks": {
      "type": "string"
    },
    "probe_checks": {
      "type": "string"
    },
    "path_safety_checks": {
      "type": "string"
    },
    "secret_checks": {
      "type": "string"
    },
    "semantic_checks": {
      "type": "string"
    },
