{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "as_of": {
      "type": "string"
    },
    "chain_hash": {
      "minLength": 16,
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "schema_version": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "domain",
    "created_at",
    "as_of",
    "chain_hash"
  ],
  "type": "object"
}
