{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "attestation_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "gate": {
      "const": "D"
    },
    "subject_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attester": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "statement": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "signature_type": {
      "enum": [
        "fixture_signature",
        "cosign",
        "gpg",
        "sigstore"
      ]
    },
    "fixture_backed": {
      "type": "boolean"
    },
    "production_use_allowed": {
      "type": "boolean"
    },
    "status": {
      "enum": [
        "fixture_attested",
        "candidate_attested",
        "needs_review",
        "blocked",
        "production_attestation_blocked"
      ]
    }
  },
  "required": [
    "schema_version",
    "domain",
    "attestation_id",
    "created_at",
    "as_of",
    "gate",
    "subject_refs",
    "attester",
    "role",
    "statement",
    "signature",
    "signature_type",
    "fixture_backed",
    "production_use_allowed",
    "status"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "signature_type": {
            "const": "fixture_signature"
          }
        }
      },
      "then": {
        "properties": {
          "production_use_allowed": {
            "const": false
          }
        }
      }
    }
  ]
}
