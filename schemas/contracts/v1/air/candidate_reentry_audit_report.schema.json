{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "audit_id",
    "domain",
    "generated_at",
    "as_of",
    "rollforward_acceptance_record_ref",
    "candidate_reentry_package_ref",
    "refreshed_baseline_recertification_ref",
    "refresh_compatibility_gate_report_ref",
    "sunset_review_queue_ref",
    "candidate_reentry_promotion_decision_ref",
    "candidate_reentry_manifest_ref",
    "candidate_reentry_postcheck_report_ref",
    "candidate_reentry_ledger_manifest_ref",
    "checks",
    "hash_checks",
    "etag_checks",
    "ledger_checks",
    "baseline_checks",
    "sunset_checks",
    "non_mutation_checks",
    "secret_checks",
    "path_safety_checks",
    "semantic_checks",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "deny"
      ]
    }
  }
}
