{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "approval_state": {
      "enum": [
        "draft_only",
        "candidate_finalized",
        "needs_review",
        "blocked",
        "production_send_blocked"
      ]
    },
    "as_of": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "created_at": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "finalization_id": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "forbidden_actions": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "message_summary": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "notice_type": {
      "enum": [
        "fixture_cutover_refresh_summary",
        "candidate_release_refresh_summary",
        "rollback_refresh_prepared_notice",
        "refresh_operation_blocked_notice",
        "production_notice_blocked"
      ]
    },
    "operational_handoff_refresh_package_ref": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "public_safe_links": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "redactions": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "release_ledger_refresh_manifest_ref": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "safety_checks": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "schema_version": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "stakeholder_notice_refresh_draft_ref": {
      "type": [
        "string",
        "array",
        "object",
        "boolean",
        "number"
      ]
    },
    "status": {
      "enum": [
        "fixture_notice_refresh_finalized",
        "candidate_notice_refresh_finalized",
        "needs_review",
        "blocked"
      ]
    }
  },
  "required": [
    "schema_version",
    "finalization_id",
    "domain",
    "created_at",
    "as_of",
    "stakeholder_notice_refresh_draft_ref",
    "release_ledger_refresh_manifest_ref",
    "operational_handoff_refresh_package_ref",
    "notice_type",
    "message_summary",
    "public_safe_links",
    "redactions",
    "approval_state",
    "forbidden_actions",
    "safety_checks",
    "status"
  ],
  "type": "object"
}
