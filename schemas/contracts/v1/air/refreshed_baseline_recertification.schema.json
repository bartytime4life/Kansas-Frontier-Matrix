{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "recertification_id",
    "domain",
    "created_at",
    "as_of",
    "candidate_reentry_package_ref",
    "assurance_baseline_rotation_ref",
    "previous_assurance_summary_ref",
    "previous_evidence_archive_manifest_ref",
    "candidate_baseline_refs",
    "recertification_scope",
    "checks",
    "findings",
    "required_followups",
    "decision",
    "signature",
    "signature_type",
    "fixture_backed",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "decision": {
      "type": "string",
      "enum": [
        "recertify_fixture_baseline",
        "recertify_candidate_baseline",
        "request_more_evidence",
        "block_baseline",
        "production_recertification_blocked"
      ]
    },
    "signature_type": {
      "type": "string",
      "enum": [
        "fixture_signature",
        "cosign",
        "gpg",
        "sigstore"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "fixture_recertified",
        "candidate_recertified",
        "needs_review",
        "blocked",
        "production_blocked"
      ]
    }
  }
}
