{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.dev/schemas/contracts/v1/air/evidence_bundle.schema.json",
  "title": "KFM Air EvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "domain",
    "created_at",
    "qa_summary_ref",
    "run_receipt_ref",
    "sources",
    "measurements",
    "provenance"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "v1"},
    "bundle_id": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "const": "atmosphere.air"},
    "created_at": {"type": "string", "format": "date-time"},
    "qa_summary_ref": {"type": "string", "minLength": 1},
    "run_receipt_ref": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "source_class", "note"],
        "properties": {
          "source_id": {"type": "string", "minLength": 1},
          "source_class": {
            "type": "string",
            "enum": ["airnow_nowcast", "epa_aqs_validated", "kansas_mesonet", "fixture"]
          },
          "note": {"type": "string", "minLength": 1}
        }
      }
    },
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameter", "units", "averaging_window", "nowcast_truth_status"],
      "properties": {
        "parameter": {"type": "string", "const": "pm25"},
        "units": {"type": "string", "const": "ug_m3"},
        "averaging_window": {"type": "string", "enum": ["nowcast_hourly", "24h_validated"]},
        "nowcast_truth_status": {
          "type": "string",
          "const": "operational_evidence_not_validated_aqs_truth"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "method"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1}
      }
    }
  }
}
