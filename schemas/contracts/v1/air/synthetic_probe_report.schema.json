{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "domain": {
      "const": "atmosphere.air"
    },
    "status": {
      "enum": [
        "pass_fixture",
        "pass_candidate",
        "warn",
        "deny"
      ]
    }
  },
  "required": [
    "schema_version",
    "probe_report_id",
    "domain",
    "generated_at",
    "as_of",
    "probe_spec_ref",
    "client_delivery_manifest_ref",
    "results",
    "failures",
    "status"
  ],
  "type": "object"
}
