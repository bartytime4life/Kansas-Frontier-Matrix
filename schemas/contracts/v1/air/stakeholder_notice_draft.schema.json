{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "as_of": {
      "type": "string"
    },
    "audience": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "created_at": {
      "type": "string"
    },
    "domain": {
      "const": "atmosphere.air"
    },
    "evidence_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "forbidden_actions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "message_summary": {
      "type": "string"
    },
    "notice_id": {
      "type": "string"
    },
    "notice_type": {
      "enum": [
        "fixture_cutover_summary",
        "candidate_release_summary",
        "rollback_prepared_notice",
        "operation_blocked_notice",
        "production_notice_blocked"
      ]
    },
    "public_safe_links": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "redactions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft_fixture",
        "draft_candidate",
        "blocked"
      ]
    },
    "subject_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "notice_id",
    "domain",
    "created_at",
    "as_of",
    "notice_type",
    "audience",
    "subject_refs",
    "evidence_refs",
    "message_summary",
    "public_safe_links",
    "redactions",
    "forbidden_actions",
    "status"
  ],
  "type": "object"
}
