{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/release_manifest.schema.json",
  "title": "Ecology Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "release_id",
    "surface",
    "release_state",
    "policy_pass",
    "published_at",
    "objects",
    "spec_hash"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "object_type": { "type": "string", "const": "ReleaseManifest" },
    "release_id": { "type": "string", "pattern": "^kfm://release/ecology/.+" },
    "title": { "type": "string" },
    "surface": {
      "type": "string",
      "enum": ["public", "restricted", "internal"]
    },
    "release_state": {
      "type": "string",
      "enum": ["published", "superseded", "withdrawn", "draft"]
    },
    "policy_pass": { "type": "boolean" },
    "published_at": { "type": "string", "format": "date-time" },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^kfm://.+" }
    },
    "catalog_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^kfm://catalog/.+" }
    },
    "receipt_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^kfm://receipt/.+" }
    },
    "correction_lineage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supersedes": { "type": ["string", "null"] },
        "superseded_by": { "type": ["string", "null"] }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "spec_hash": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$" }
  }
}
