{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/ecology_observation_bundle.schema.json",
  "title": "Ecology Observation Bundle",
  "description": "Governed container for grouped ecology observations and derived artifacts. Represents a resolved EvidenceBundle suitable for policy evaluation and publication decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "bundle_id",
    "source_refs",
    "dataset_refs",
    "policy_id",
    "policy_label",
    "sensitivity",
    "rights_status",
    "spec_hash",
    "evidence_refs",
    "evidence_bundle_resolved"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "EcologyObservationBundle"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^kfm://bundle/ecology/.+"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dataset_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "catalog_refs": {
      "type": [
        "object",
        "array"
      ]
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_label": {
      "type": "string",
      "enum": [
        "public",
        "restricted",
        "internal",
        "restricted_until_reviewed",
        "public_after_catalog_closure"
      ]
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "generalize",
        "restricted",
        "review_required"
      ]
    },
    "rights_status": {
      "type": "string",
      "enum": [
        "public",
        "open",
        "controlled",
        "restricted",
        "unknown"
      ]
    },
    "public_visibility": {
      "type": "string",
      "enum": [
        "withheld",
        "generalized",
        "internal_only"
      ]
    },
    "public_geometry_policy": {
      "type": "string",
      "enum": [
        "deny_exact_generalize_required",
        "suppress",
        "restricted_only"
      ]
    },
    "exact_geometry_present": {
      "type": "boolean"
    },
    "redaction_receipt_ref": {
      "type": "string",
      "pattern": "^kfm://receipt/redaction/.+"
    },
    "publication_state": {
      "type": "string",
      "enum": [
        "candidate",
        "reviewed",
        "published",
        "held",
        "quarantined",
        "superseded"
      ]
    },
    "surface": {
      "type": "string",
      "enum": [
        "public",
        "restricted",
        "internal"
      ]
    },
    "catalog_closure": {
      "type": "boolean"
    },
    "evidence_bundle_resolved": {
      "type": "boolean"
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^kfm://evidence/.+"
      }
    }
  }
}
