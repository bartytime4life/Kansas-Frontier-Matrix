{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/sensitive_occurrence_record.schema.json",
  "title": "Sensitive Occurrence Record",
  "description": "Governed ecology occurrence record for sensitive taxa, exact locations, private-access sites, or other restricted biodiversity observations. Exact geometry is restricted by default and public release requires reviewed geoprivacy handling.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "occurrence_id",
    "taxon_id",
    "taxon_ref",
    "source_id",
    "source_role",
    "source_ref",
    "sensitivity",
    "sensitivity_class",
    "geometry_private",
    "public_geometry_policy",
    "public_visibility",
    "policy_id",
    "policy_label",
    "rights_status",
    "spec_hash",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "SensitiveOccurrenceRecord"
    },
    "occurrence_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^kfm://occurrence/.+"
    },
    "taxon_id": {
      "type": "string",
      "minLength": 1
    },
    "taxon_ref": {
      "type": "string",
      "pattern": "^kfm://taxon/.+"
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_role": {
      "type": "string",
      "const": "SENSITIVE_OCCURRENCE"
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "restricted",
        "review_required",
        "generalize"
      ]
    },
    "sensitivity_class": {
      "type": "string",
      "enum": [
        "rare_species_exact_location",
        "private_access_site",
        "threatened_or_endangered_species",
        "culturally_sensitive_location",
        "other_sensitive_occurrence"
      ]
    },
    "geometry_private": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "Point",
            "Polygon",
            "MultiPolygon"
          ]
        },
        "coordinates": {}
      },
      "additionalProperties": true
    },
    "restricted_geometry_ref": {
      "type": "string",
      "pattern": "^kfm://restricted/geometry/.+"
    },
    "geometry_public": {
      "type": [
        "object",
        "null"
      ]
    },
    "generalized_geometry_ref": {
      "type": "string",
      "pattern": "^kfm://geometry/generalized/.+"
    },
    "generalization_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "precision_served": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "coarse_cell",
        "admin_polygon",
        "suppressed",
        null
      ]
    },
    "public_geometry_policy": {
      "type": "string",
      "enum": [
        "deny_exact_generalize_required",
        "suppress",
        "restricted_only"
      ]
    },
    "public_visibility": {
      "type": "string",
      "enum": [
        "withheld",
        "generalized",
        "internal_only"
      ]
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_label": {
      "type": "string",
      "enum": [
        "restricted",
        "internal"
      ]
    },
    "rights_status": {
      "type": "string",
      "enum": [
        "controlled",
        "restricted",
        "unknown",
        "dua_required"
      ]
    },
    "redaction_receipt_ref": {
      "type": "string",
      "pattern": "^kfm://receipt/redaction/.+"
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^kfm://evidence/.+"
      }
    }
  }
}
