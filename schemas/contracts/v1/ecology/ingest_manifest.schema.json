{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/ingest_manifest.schema.json",
  "title": "KFM Ecology Ingest Manifest",
  "description": "Schema for ingest_manifest.json emitted by the ecology HLS/Landsat ingest scaffold.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "source_uris",
    "sensor",
    "collection_version",
    "bbox",
    "time_start",
    "time_end",
    "canonicalization_alg",
    "canonical_spec_hash",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "EcologyIngestManifest"
    },
    "source_uris": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sensor": {
      "type": "string",
      "enum": [
        "HLS",
        "Landsat-8",
        "Landsat-9",
        "Sentinel-2"
      ]
    },
    "collection_version": {
      "type": "string",
      "minLength": 1
    },
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "time_start": {
      "type": "string",
      "format": "date-time"
    },
    "time_end": {
      "type": "string",
      "format": "date-time"
    },
    "canonicalization_alg": {
      "type": "string",
      "const": "JCS@v1"
    },
    "canonical_spec_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
