{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/focus_mode_request.schema.json",
  "title": "Ecology Focus Mode Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "request_id",
    "query",
    "surface",
    "policy_label",
    "sensitivity",
    "rights_status",
    "spec_hash"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "FocusModeRequest"
    },
    "request_id": {
      "type": "string",
      "pattern": "^kfm://request/ecology/.+"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "type": "string",
      "enum": [
        "public",
        "restricted",
        "internal"
      ]
    },
    "policy_label": {
      "type": "string",
      "minLength": 1
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "generalize",
        "restricted",
        "review_required"
      ]
    },
    "rights_status": {
      "type": "string",
      "enum": [
        "public",
        "open",
        "controlled",
        "restricted",
        "unknown"
      ]
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "taxon_ref": {
      "type": "string",
      "pattern": "^kfm://taxon/.+"
    },
    "geometry_ref": {
      "type": "string",
      "pattern": "^kfm://(geometry|restricted/geometry)/.+"
    },
    "exact_geometry_present": {
      "type": "boolean"
    },
    "public_visibility": {
      "type": "string",
      "enum": [
        "public",
        "generalized",
        "internal_only",
        "restricted"
      ]
    },
    "claim_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^kfm://claim/ecology/.+"
      }
    },
    "evidence_bundle_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^kfm://evidence/ecology/.+"
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_inference": {
          "type": "boolean"
        },
        "require_evidence": {
          "type": "boolean"
        }
      }
    }
  }
}
