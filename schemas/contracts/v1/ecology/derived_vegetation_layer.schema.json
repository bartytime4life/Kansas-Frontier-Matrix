{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/derived_vegetation_layer.schema.json",
  "title": "Derived Vegetation Layer",
  "description": "Governed ecology layer record for modeled or derived vegetation products. Derived layers must remain labeled as derived/model context unless separately promoted by evidence and review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "layer_id",
    "title",
    "source_id",
    "source_role",
    "derivation_method",
    "source_refs",
    "time_window",
    "spec_hash",
    "classification",
    "derived_status",
    "policy_label",
    "publication_state",
    "evidence_refs",
    "catalog_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "DerivedVegetationLayer"
    },
    "layer_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^kfm://layer/.+"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_role": {
      "type": "string",
      "const": "DERIVED_MODEL_LAYER"
    },
    "product": {
      "type": "string",
      "enum": [
        "LANDFIRE_EVT",
        "LANDFIRE_EVC",
        "LANDFIRE_EVH",
        "NDVI_DERIVED",
        "OTHER_DERIVED"
      ]
    },
    "version": {
      "type": "string"
    },
    "derivation_method": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "time_window": {
      "type": "object",
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "string",
          "format": "date"
        },
        "end": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },
    "classification": {
      "type": "string",
      "enum": [
        "model",
        "derived_context"
      ]
    },
    "derived_status": {
      "type": "string",
      "enum": [
        "modeled",
        "derived",
        "classified",
        "interpolated"
      ]
    },
    "spatial_resolution_m": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "policy_label": {
      "type": "string",
      "enum": [
        "internal",
        "restricted",
        "public_after_catalog_closure",
        "public"
      ]
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^kfm://evidence/.+"
      }
    },
    "catalog_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stac",
        "prov"
      ],
      "properties": {
        "stac": {
          "type": "string",
          "pattern": "^kfm://catalog/stac/.+"
        },
        "dcat": {
          "type": "string",
          "pattern": "^kfm://catalog/dcat/.+"
        },
        "prov": {
          "type": "string",
          "pattern": "^kfm://catalog/prov/.+"
        }
      }
    },
    "publication_state": {
      "type": "string",
      "enum": [
        "candidate",
        "reviewed",
        "published",
        "held",
        "quarantined",
        "superseded"
      ]
    }
  }
}
