{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/qa_summary.schema.json",
  "title": "KFM Ecology QA Summary",
  "description": "Schema for qa_summary.json emitted by the ecology HLS/Landsat ingest scaffold.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "total_pixels",
    "masked_pixels",
    "aerosol_flagged_pixels",
    "total_30m_pixels",
    "valid_30m_pixels",
    "masked_pct",
    "aerosol_flag_pct",
    "valid_30m_coverage_pct"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "EcologyQaSummary"
    },
    "total_pixels": {
      "type": "integer",
      "minimum": 1
    },
    "masked_pixels": {
      "type": "integer",
      "minimum": 0
    },
    "aerosol_flagged_pixels": {
      "type": "integer",
      "minimum": 0
    },
    "total_30m_pixels": {
      "type": "integer",
      "minimum": 1
    },
    "valid_30m_pixels": {
      "type": "integer",
      "minimum": 0
    },
    "masked_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "aerosol_flag_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "valid_30m_coverage_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  }
}
