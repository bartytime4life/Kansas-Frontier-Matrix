{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/stac_item.schema.json",
  "title": "KFM Ecology STAC Item",
  "description": "Schema for a minimal KFM Ecology STAC Item emitted by the time-slice publication pipeline.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "type",
    "stac_version",
    "id",
    "collection",
    "bbox",
    "geometry",
    "properties",
    "links",
    "assets"
  ],
  "properties": {
    "type": {
      "type": "string",
      "const": "Feature"
    },
    "stac_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "collection": {
      "type": "string",
      "minLength": 1
    },
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "Polygon"
        },
        "coordinates": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "properties": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "datetime",
        "start_datetime",
        "end_datetime",
        "created",
        "kfm:domain",
        "kfm:evidence_bundle",
        "kfm:promotion_decision",
        "kfm:spec_hash",
        "kfm:provisional",
        "kfm:expected_tile_count",
        "kfm:produced_tile_count",
        "kfm:allowed_fields",
        "kfm:item_hash"
      ],
      "properties": {
        "datetime": {
          "type": "string",
          "format": "date-time"
        },
        "start_datetime": {
          "type": "string",
          "format": "date-time"
        },
        "end_datetime": {
          "type": "string",
          "format": "date-time"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "kfm:domain": {
          "type": "string",
          "const": "ecology"
        },
        "kfm:evidence_bundle": {
          "type": "string",
          "pattern": "^kfm://evidence/ecology/.+"
        },
        "kfm:promotion_decision": {
          "type": "string",
          "pattern": "^kfm://promotion/ecology/.+"
        },
        "kfm:spec_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "kfm:provisional": {
          "type": "boolean"
        },
        "kfm:expected_tile_count": {
          "type": [
            "integer",
            "number",
            "null"
          ],
          "minimum": 0
        },
        "kfm:produced_tile_count": {
          "type": [
            "integer",
            "number",
            "null"
          ],
          "minimum": 0
        },
        "kfm:allowed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kfm:item_hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        }
      }
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "rel",
          "href"
        ],
        "properties": {
          "rel": {
            "type": "string",
            "minLength": 1
          },
          "href": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "href",
          "roles",
          "type"
        ],
        "properties": {
          "href": {
            "type": "string",
            "minLength": 1
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          }
        }
      }
    }
  }
}
