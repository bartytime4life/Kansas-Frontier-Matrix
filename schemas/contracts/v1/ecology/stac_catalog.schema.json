{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/stac_catalog.schema.json",
  "title": "KFM Ecology STAC Catalog",
  "description": "Schema for a minimal KFM Ecology STAC Catalog generated from governed STAC Collections.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "stac_version",
    "type",
    "id",
    "title",
    "description",
    "links",
    "kfm:domain",
    "kfm:collection_count"
  ],
  "properties": {
    "stac_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "type": {
      "type": "string",
      "const": "Catalog"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "rel",
          "href"
        ],
        "properties": {
          "rel": {
            "type": "string",
            "minLength": 1
          },
          "href": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      }
    },
    "kfm:domain": {
      "type": "string",
      "const": "ecology"
    },
    "kfm:collection_count": {
      "type": "integer",
      "minimum": 1
    }
  }
}
