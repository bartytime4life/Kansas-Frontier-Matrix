{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/tileset_metadata.schema.json",
  "title": "KFM Ecology Tileset Metadata",
  "description": "Schema for tileset_metadata.json emitted by the ecology ingest scaffold.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "scheme",
    "bounds",
    "minzoom",
    "maxzoom",
    "time_start",
    "time_end",
    "expected_tile_count",
    "produced_tile_count",
    "kfm",
    "evidence_bundle_url",
    "provisional",
    "allowed_fields"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "EcologyTilesetMetadata"
    },
    "scheme": {
      "type": "string",
      "enum": ["xyz"]
    },
    "bounds": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "minzoom": {
      "type": "integer",
      "minimum": 0
    },
    "maxzoom": {
      "type": "integer",
      "minimum": 0
    },
    "time_start": {
      "type": "string",
      "format": "date-time"
    },
    "time_end": {
      "type": "string",
      "format": "date-time"
    },
    "expected_tile_count": {
      "type": "integer",
      "minimum": 0
    },
    "produced_tile_count": {
      "type": "integer",
      "minimum": 0
    },
    "kfm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spec_hash"],
      "properties": {
        "spec_hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        }
      }
    },
    "evidence_bundle_url": {
      "type": "string",
      "pattern": "^kfm://evidence/ecology/.+"
    },
    "provisional": {
      "type": "boolean"
    },
    "allowed_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
