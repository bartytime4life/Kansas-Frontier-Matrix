{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/layer_manifest.schema.json",
  "title": "KFM Ecology Layer Manifest",
  "description": "Public-safe MapLibre layer manifest for a governed KFM Ecology time-slice layer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "layer_id",
    "title",
    "source_type",
    "tiles_url",
    "source_layer",
    "stac_catalog_ref",
    "stac_collection_ref",
    "evidence_bundle_ref",
    "promotion_decision_ref",
    "run_receipt_ref",
    "minzoom",
    "maxzoom",
    "allowed_fields",
    "public_safe"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "EcologyLayerManifest"
    },
    "layer_id": {
      "type": "string",
      "pattern": "^kfm://layer/ecology/.+"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "vector",
        "raster",
        "raster-dem",
        "geojson"
      ]
    },
    "tiles_url": {
      "type": "string",
      "minLength": 1
    },
    "source_layer": {
      "type": "string",
      "minLength": 1
    },
    "stac_catalog_ref": {
      "type": "string",
      "pattern": "^kfm://catalog/stac.*"
    },
    "stac_collection_ref": {
      "type": "string",
      "pattern": "^kfm://catalog/stac/collections/.+"
    },
    "stac_item_ref": {
      "type": "string",
      "pattern": "^kfm://catalog/stac/items/.+"
    },
    "evidence_bundle_ref": {
      "type": "string",
      "pattern": "^kfm://evidence/ecology/.+"
    },
    "promotion_decision_ref": {
      "type": "string",
      "pattern": "^kfm://promotion/ecology/.+"
    },
    "run_receipt_ref": {
      "type": "string",
      "pattern": "^kfm://receipt/run/ecology/.+"
    },
    "minzoom": {
      "type": "integer",
      "minimum": 0
    },
    "maxzoom": {
      "type": "integer",
      "minimum": 0
    },
    "bounds": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "time_start": {
      "type": "string",
      "format": "date-time"
    },
    "time_end": {
      "type": "string",
      "format": "date-time"
    },
    "allowed_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "public_safe": {
      "type": "boolean",
      "const": true
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "generalize"
      ]
    },
    "rights_status": {
      "type": "string",
      "enum": [
        "public",
        "open"
      ]
    },
    "policy_label": {
      "type": "string"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
