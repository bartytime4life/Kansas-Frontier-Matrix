{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/evidence_bundle.schema.json",
  "title": "Ecology Evidence Bundle",
  "description": "Contract for a resolved KFM Ecology EvidenceBundle used by publication policy, receipts, UI payloads, and dry-run time-slice evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "bundle_id",
    "domain",
    "source_refs",
    "dataset_refs",
    "evidence_refs",
    "object_refs",
    "resolved",
    "evidence_bundle_resolved",
    "policy_label",
    "rights_status",
    "sensitivity",
    "spec_hash"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "object_type": {
      "type": "string",
      "const": "EvidenceBundle"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^kfm://evidence/ecology/.+"
    },
    "domain": {
      "type": "string",
      "const": "ecology"
    },
    "title": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dataset_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^kfm://evidence/.+"
      }
    },
    "object_refs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "pattern": "^kfm://.+"
      }
    },
    "resolved": {
      "type": "boolean"
    },
    "evidence_bundle_resolved": {
      "type": "boolean"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_label": {
      "type": "string",
      "minLength": 1
    },
    "rights_status": {
      "type": "string",
      "enum": [
        "public",
        "open",
        "controlled",
        "restricted",
        "unknown"
      ]
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "generalize",
        "restricted",
        "review_required"
      ]
    },
    "surface": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "restricted"
      ]
    },
    "publication_state": {
      "type": "string",
      "enum": [
        "candidate",
        "held",
        "quarantined",
        "published",
        "released",
        "ready"
      ]
    },
    "source_role": {
      "type": "string",
      "minLength": 1
    },
    "claim_status": {
      "type": "string",
      "enum": [
        "CONFIRMED",
        "PROPOSED",
        "UNKNOWN",
        "NEEDS_VERIFICATION",
        "CONFLICTED",
        "SUPERSEDED"
      ]
    },
    "catalog_closure": {
      "type": "boolean"
    },
    "catalog_refs": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stac": {
              "type": "string",
              "pattern": "^kfm://.+"
            },
            "dcat": {
              "type": "string",
              "pattern": "^kfm://.+"
            },
            "prov": {
              "type": "string",
              "pattern": "^kfm://.+"
            }
          }
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^kfm://.+"
          }
        }
      ]
    },
    "exact_geometry_present": {
      "type": "boolean"
    },
    "public_geometry_policy": {
      "type": "string"
    },
    "public_visibility": {
      "type": "string",
      "enum": [
        "public",
        "generalized",
        "internal_only",
        "restricted"
      ]
    },
    "redaction_receipt_ref": {
      "type": "string",
      "pattern": "^kfm://receipts/.+"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "uri",
          "media_type",
          "digest"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          }
        }
      }
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 0
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "asset_id"
        ],
        "properties": {
          "asset_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "checksum": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          },
          "public_safe": {
            "type": "boolean"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    }
  }
}
