{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/evidence_bundle.schema.json",
  "title": "Ecology Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "bundle_id",
    "source_refs",
    "dataset_refs",
    "evidence_refs",
    "object_refs",
    "resolved",
    "policy_label",
    "rights_status",
    "sensitivity",
    "spec_hash"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "object_type": { "type": "string", "const": "EvidenceBundle" },
    "bundle_id": { "type": "string", "pattern": "^kfm://evidence/ecology/.+" },
    "title": { "type": "string" },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "dataset_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^kfm://evidence/.+" }
    },
    "object_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^kfm://.+" }
    },
    "resolved": { "type": "boolean" },
    "policy_label": { "type": "string" },
    "rights_status": {
      "type": "string",
      "enum": ["public", "open", "controlled", "restricted", "unknown"]
    },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "generalize", "restricted", "review_required"]
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "spec_hash": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$" }
  }
}
