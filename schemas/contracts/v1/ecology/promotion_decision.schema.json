{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/contracts/v1/ecology/promotion_decision.schema.json",
  "title": "KFM Ecology Promotion Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "object_type",
    "decision_id",
    "candidate",
    "decision",
    "reasons",
    "requires_steward",
    "receipt_ref",
    "decided_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "object_type": { "type": "string", "const": "PromotionDecision" },
    "decision_id": {
      "type": "string",
      "pattern": "^kfm://promotion/ecology/.+"
    },
    "candidate": {
      "type": "string",
      "pattern": "^kfm://.+"
    },
    "decision": {
      "type": "string",
      "enum": ["PROMOTE", "DENY", "REVIEW"]
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requires_steward": { "type": "boolean" },
    "receipt_ref": {
      "type": "string",
      "pattern": "^kfm://receipt/run/.+"
    },
    "evidence_bundle_url": { "type": "string" },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
