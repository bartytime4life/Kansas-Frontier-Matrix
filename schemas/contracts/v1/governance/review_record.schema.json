{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kfm.local/contracts/v1/governance/review_record.schema.json",
  "title": "review_record",
  "type": "object",
  "description": "KFM contract for review_record.",
  "x-kfm": {
    "contract_doc": "contracts/governance/review_record.md",
    "fixtures_root": "fixtures/contracts/v1/governance/review_record/",
    "validator": "tools/validators/validate_review_record.py",
    "policy": "policy/governance/",
    "status": "PROPOSED"
  },
  "properties": {
    "review_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:.-]*$"
    },
    "subject_ref": {
      "type": "string"
    },
    "reviewer_role": {
      "type": "string",
      "enum": [
        "steward",
        "reviewer",
        "auditor"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "reject",
        "request_changes"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "review_id",
    "subject_ref",
    "reviewer_role",
    "decision",
    "reasons",
    "obligations",
    "reviewed_at"
  ],
  "additionalProperties": false
}
