{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kfm.local/contracts/v1/evidence/evidence_bundle.schema.json",
  "title": "evidence_bundle",
  "type": "object",
  "description": "KFM contract for evidence_bundle.",
  "x-kfm": {
    "contract_doc": "contracts/evidence/evidence_bundle.md",
    "fixtures_root": "fixtures/contracts/v1/evidence/evidence_bundle/",
    "validator": "tools/validators/validate_evidence_bundle.py",
    "policy": "policy/evidence/",
    "status": "PROPOSED"
  },
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "claim_scope": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.kfm.local/contracts/v1/evidence/evidence_ref.schema.json"
      },
      "minItems": 1
    },
    "source_records": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "rights": {
      "type": "object",
      "required": [
        "license"
      ],
      "properties": {
        "license": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "sensitivity": {
      "$ref": "https://schemas.kfm.local/contracts/v1/policy/sensitivity_label.schema.json"
    },
    "transforms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checksums": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      }
    },
    "spec_hash": {
      "$ref": "https://schemas.kfm.local/contracts/v1/common/spec_hash.schema.json"
    }
  },
  "required": [
    "bundle_id",
    "claim_scope",
    "evidence_refs",
    "source_records",
    "citations",
    "rights",
    "sensitivity",
    "transforms",
    "checksums",
    "spec_hash"
  ],
  "additionalProperties": false
}
