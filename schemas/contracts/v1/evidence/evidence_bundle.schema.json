{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.example/schemas/contracts/v1/evidence/evidence_bundle.schema.json",
  "title": "EvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "evidence_bundle_id",
    "decision_envelope_ref",
    "release_manifest_ref",
    "attestation_refs"
  ],
  "properties": {
    "kind": { "const": "EvidenceBundle" },
    "schema_version": { "const": "v1" },
    "evidence_bundle_id": { "type": "string", "minLength": 1 },
    "decision_envelope_ref": { "type": "string", "minLength": 1 },
    "release_manifest_ref": { "type": "string", "minLength": 1 },
    "run_receipt_ref": { "type": "string", "minLength": 1 },
    "ai_receipt_ref": { "type": "string", "minLength": 1 },
    "attestation_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
