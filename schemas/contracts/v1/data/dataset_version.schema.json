{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.example/schemas/contracts/v1/data/dataset_version.schema.json",
  "title": "DatasetVersion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "dataset_version_id",
    "dataset_id",
    "stage",
    "source_descriptor_ref",
    "produced_at",
    "spec_hash"
  ],
  "properties": {
    "kind": { "const": "DatasetVersion" },
    "schema_version": { "const": "v1" },
    "dataset_version_id": { "type": "string", "minLength": 1 },
    "dataset_id": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "enum": ["WORK", "QUARANTINE", "PROCESSED", "CATALOG"] },
    "source_descriptor_ref": { "type": "string", "minLength": 1 },
    "produced_at": { "type": "string", "format": "date-time" },
    "spec_hash": { "type": "string", "minLength": 8 }
  }
}
