{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "ledger_id",
    "entries",
    "chain_hash"
  ],
  "properties": {
    "object_type": {
      "const": "PromotionCorrectionLedger"
    },
    "schema_version": {
      "const": "v1"
    },
    "ledger_id": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "event_id",
          "event_type",
          "timestamp",
          "entry_hash"
        ],
        "properties": {
          "event_id": {
            "type": "string"
          },
          "event_type": {
            "enum": [
              "correction",
              "withdrawal",
              "rollback"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "entry_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "chain_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
