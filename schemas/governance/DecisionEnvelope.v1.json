{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_type",
    "schema_version",
    "decision_id",
    "decision",
    "subject_artifact_id",
    "subject_artifact_spec_hash",
    "evidence_bundle_id",
    "evidence_bundle_hash",
    "run_receipt_id",
    "run_receipt_hash",
    "policy_profile_url",
    "policy_profile_hash",
    "consent_vc_id",
    "revoke_delta_id",
    "release_channel",
    "export_format",
    "reasons",
    "evaluated_at",
    "evaluator",
    "signature"
  ],
  "properties": {
    "object_type": {
      "const": "DecisionEnvelope"
    },
    "schema_version": {
      "const": "v1"
    },
    "decision_id": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "allow",
        "deny",
        "suppress",
        "recompute_required",
        "quarantine"
      ]
    },
    "subject_artifact_id": {
      "type": "string"
    },
    "subject_artifact_spec_hash": {
      "type": "string"
    },
    "evidence_bundle_id": {
      "type": "string"
    },
    "evidence_bundle_hash": {
      "type": "string"
    },
    "run_receipt_id": {
      "type": "string"
    },
    "run_receipt_hash": {
      "type": "string"
    },
    "policy_profile_url": {
      "type": "string"
    },
    "policy_profile_hash": {
      "type": "string"
    },
    "consent_vc_id": {
      "type": "string"
    },
    "revoke_delta_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "release_channel": {
      "enum": [
        "internal",
        "controlled",
        "public",
        "export"
      ]
    },
    "export_format": {
      "type": [
        "string",
        "null"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "detail"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "check": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "evaluated_at": {
      "type": "string"
    },
    "evaluator": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    }
  }
}