{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schema/catalog/dcat_dataset.schema.json",
  "title": "KFM DCAT Dataset",
  "type": "object",
  "required": ["@type", "@id", "kfm:spec_hash", "dcat:distribution"],
  "properties": {
    "@context": { "type": ["object", "string", "array"] },
    "@type": { "const": "dcat:Dataset" },
    "@id": { "type": "string", "minLength": 1 },
    "dct:title": { "type": "string" },
    "dct:identifier": { "type": "string" },
    "dct:issued": { "type": "string" },
    "dct:modified": { "type": "string" },
    "dct:license": { "type": ["string", "null"] },
    "dct:rightsHolder": { "type": ["string", "null"] },
    "kfm:spec_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "kfm:records": { "type": "integer", "minimum": 0 },
    "kfm:format": { "type": ["string", "null"] },
    "dcat:distribution": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["@type", "dcat:accessURL"],
        "properties": {
          "@type": { "const": "dcat:Distribution" },
          "dcat:accessURL": { "type": "string", "minLength": 1 },
          "dct:format": { "type": ["string", "null"] },
          "kfm:spec_hash": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
