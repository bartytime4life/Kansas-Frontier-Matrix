{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schema/catalog/stac_collection.schema.json",
  "title": "KFM STAC Collection",
  "type": "object",
  "required": ["type", "stac_version", "id", "links", "summaries"],
  "properties": {
    "type": { "const": "Collection" },
    "stac_version": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "license": { "type": "string" },
    "extent": { "type": "object" },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rel", "href"],
        "properties": {
          "rel": { "type": "string", "minLength": 1 },
          "href": { "type": "string", "minLength": 1 },
          "type": { "type": "string" },
          "title": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "summaries": {
      "type": "object",
      "required": ["kfm:spec_hash"],
      "properties": {
        "kfm:spec_hash": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^sha256:[a-fA-F0-9]{64}$"
          }
        },
        "kfm:records": {
          "type": "array",
          "items": { "type": ["integer", "null"], "minimum": 0 }
        },
        "kfm:format": {
          "type": "array",
          "items": { "type": ["string", "null"] }
        },
        "kfm:partitioning": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
