{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceBundle starter schema",
  "type": "object",
  "required": [
    "bundle_id",
    "version",
    "created_at",
    "producer",
    "subject",
    "artifacts",
    "spec_hash",
    "rights"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "required": [
        "id"
      ]
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1
    },
    "rights": {
      "type": "object"
    }
  }
}
