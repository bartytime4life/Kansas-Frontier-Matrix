{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.dev/schemas/maps/signed_release_manifest.schema.json",
  "title": "KFM Signed Release Manifest",
  "type": "object",
  "required": ["manifest_id","release_state","policy_label","artifacts","signature"],
  "properties": {"manifest_id": {"type":"string","pattern":"^kfm-map-release-[a-z0-9._-]+$"},"release_state": {"const":"released"},"policy_label": {"const":"public-safe"},"signer_identity": {"type":"string"},"trust_root_expires_at": {"type":"string","format":"date-time"},"artifacts": {"type":"array","minItems":1,"items": {"type":"object","required":["artifact_id","kind","href","digest"],"properties":{"artifact_id":{"type":"string"},"kind":{"enum":["pmtiles","tilejson"]},"href":{"type":"string"},"digest":{"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},"metadata":{"type":"object"}},"additionalProperties":false}},"signature": {"type":"object","required":["bundle","signature","signed_digest"],"properties":{"bundle":{"type":"object"},"signature":{"type":"string","minLength":1},"signed_digest":{"type":"string","pattern":"^sha256:[a-f0-9]{64}$"}},"additionalProperties":false}},
  "additionalProperties": false
}
