{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "object_type",
    "release_evidence_id",
    "hash_algorithm",
    "indexDigest",
    "result",
    "required_refs",
    "tiles",
    "public_artifacts",
    "runtime_contract",
    "trace",
    "rollback_ref",
    "correction_ref",
    "sensitivity",
    "rights"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "object_type": {
      "const": "VerifiedTileReleaseEvidence"
    },
    "release_evidence_id": {
      "type": "string"
    },
    "hash_algorithm": {
      "enum": [
        "sha256"
      ]
    },
    "indexDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "result": {
      "enum": [
        "ALLOW",
        "DENY",
        "ERROR"
      ]
    },
    "required_refs": {
      "type": "object",
      "required": [
        "EvidenceBundle",
        "ReleaseManifest",
        "RunReceipt",
        "VerifierTrace"
      ],
      "properties": {
        "EvidenceBundle": {
          "type": "string"
        },
        "ReleaseManifest": {
          "type": "string"
        },
        "RunReceipt": {
          "type": "string"
        },
        "VerifierTrace": {
          "type": "string"
        }
      }
    },
    "tiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "tile_id",
          "digest",
          "change_type"
        ],
        "properties": {
          "tile_id": {
            "type": "string"
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "prior_digest": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "change_type": {
            "enum": [
              "added",
              "modified",
              "removed"
            ]
          },
          "bytes_ref": {
            "type": "string"
          }
        }
      }
    },
    "public_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime_contract": {
      "type": "object",
      "required": [
        "schema_version",
        "object_type",
        "runtime_contract_id",
        "render_mode",
        "allow_unverified_render"
      ],
      "properties": {
        "schema_version": {
          "const": "v1"
        },
        "object_type": {
          "const": "TileRuntimeVerificationContract"
        },
        "runtime_contract_id": {
          "type": "string"
        },
        "render_mode": {
          "enum": [
            "verified_only"
          ]
        },
        "allow_unverified_render": {
          "const": false
        }
      }
    },
    "trace": {
      "type": "object"
    },
    "rollback_ref": {
      "type": "string"
    },
    "correction_ref": {
      "type": "string"
    },
    "sensitivity": {
      "enum": [
        "public_safe"
      ]
    },
    "rights": {
      "enum": [
        "public"
      ]
    }
  },
  "additionalProperties": true
}
