{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "object_type",
    "verification_receipt_id",
    "result",
    "proof_bundle_ref",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "object_type": {
      "const": "TileVerificationReceipt"
    },
    "verification_receipt_id": {
      "type": "string"
    },
    "result": {
      "enum": [
        "ALLOW",
        "DENY",
        "ERROR"
      ]
    },
    "proof_bundle_ref": {
      "type": "string"
    },
    "summary": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
