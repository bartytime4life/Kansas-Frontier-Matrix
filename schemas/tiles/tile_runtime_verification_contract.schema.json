{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "object_type",
    "runtime_contract_id",
    "render_mode",
    "allow_unverified_render"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "object_type": {
      "const": "TileRuntimeVerificationContract"
    },
    "runtime_contract_id": {
      "type": "string"
    },
    "render_mode": {
      "enum": [
        "verified_only"
      ]
    },
    "allow_unverified_render": {
      "const": false
    }
  },
  "additionalProperties": true
}
