{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/tiles/pmtiles_delta_manifest.schema.json",
  "title": "KFM PMTiles Delta Manifest",
  "type": "object",
  "required": [
    "version",
    "spec_hash",
    "generated_at",
    "release_state",
    "cache_control",
    "base_archive",
    "delta_archive",
    "masked_pct",
    "coverage_pct",
    "attestations",
    "proof_refs",
    "signature_refs",
    "rights",
    "license",
    "geoprivacy",
    "release_ref",
    "promotion_ref"
  ],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "spec_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "release_state": {"type": "string", "enum": ["PUBLIC", "RELEASED", "INTERNAL"]},
    "cache_control": {"type": "string", "minLength": 1},
    "base_archive": {
      "type": "object",
      "required": ["href", "digest", "zoom_min", "zoom_max", "bbox"],
      "properties": {
        "href": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "zoom_min": {"type": "integer", "minimum": 0},
        "zoom_max": {"type": "integer", "minimum": 0},
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {"type": "number"}
        }
      },
      "additionalProperties": false
    },
    "delta_archive": {
      "type": "object",
      "required": [
        "href",
        "digest",
        "zoom_min",
        "zoom_max",
        "bbox",
        "tile_count",
        "expected_tile_count",
        "completeness_pct"
      ],
      "properties": {
        "href": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "zoom_min": {"type": "integer", "minimum": 0},
        "zoom_max": {"type": "integer", "minimum": 0},
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {"type": "number"}
        },
        "tile_count": {"type": "integer", "minimum": 0},
        "expected_tile_count": {"type": "integer", "minimum": 1},
        "completeness_pct": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "masked_pct": {"type": "number", "minimum": 0, "maximum": 1},
    "coverage_pct": {"type": "number", "minimum": 0, "maximum": 1},
    "attestations": {
      "type": "object",
      "required": ["steward", "reviewer"],
      "properties": {
        "steward": {"type": "string"},
        "reviewer": {"type": "string"}
      },
      "additionalProperties": false
    },
    "proof_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "signature_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "rights": {"type": "string", "minLength": 1},
    "license": {"type": "string", "minLength": 1},
    "geoprivacy": {
      "type": "object",
      "required": ["sensitive_geometry", "redaction_receipt"],
      "properties": {
        "sensitive_geometry": {"type": "boolean"},
        "redaction_receipt": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "release_ref": {"type": "string", "minLength": 1},
    "promotion_ref": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
