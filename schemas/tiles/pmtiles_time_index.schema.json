{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm.local/schemas/tiles/pmtiles_time_index.schema.json",
  "title": "KFM PMTiles Time Index",
  "type": "object",
  "required": ["version", "spec_hash", "generated_at", "base_archives", "delta_manifests"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "spec_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "base_archives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["href", "digest", "effective_at"],
        "properties": {
          "href": {"type": "string", "minLength": 1},
          "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "effective_at": {"type": "string", "format": "date-time"}
        },
        "additionalProperties": false
      }
    },
    "delta_manifests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["href", "digest", "generated_at", "release_ref", "promotion_ref"],
        "properties": {
          "href": {"type": "string", "minLength": 1},
          "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "generated_at": {"type": "string", "format": "date-time"},
          "release_ref": {"type": "string", "minLength": 1},
          "promotion_ref": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
