{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kfm/schemas/hydrology/huc12_comid_catalog_record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_type","layer_type","huc12","manifest_id","timeslice_id","snapshot_id","nhd_snapshot_id",
    "spec_hash","valid_from","valid_to","release_state","manifest_digest","crosswalk_digest",
    "published_manifest_uri","published_crosswalk_uri","evidence_bundle_uri","run_receipt_url","evidence_drawer"
  ],
  "properties": {
    "record_type": {"const": "huc12_comid_catalog_record"},
    "layer_type": {"const": "huc12"},
    "huc12": {"type": "string", "pattern": "^[0-9]{12}$"},
    "manifest_id": {"type": "string", "minLength": 1},
    "timeslice_id": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "nhd_snapshot_id": {"type": "string", "minLength": 1},
    "spec_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{6,}$"},
    "valid_from": {"type": "string", "format": "date-time"},
    "valid_to": {"type": "string", "format": "date-time"},
    "release_state": {"enum": ["cataloged", "published", "revoked"]},
    "manifest_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{6,}$"},
    "crosswalk_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{6,}$"},
    "published_manifest_uri": {"type": "string", "pattern": "^(?!.*\/(raw|work|quarantine)\/).+"},
    "published_crosswalk_uri": {"type": "string", "pattern": "^(?!.*\/(raw|work|quarantine)\/).+"},
    "evidence_bundle_uri": {"type": "string", "pattern": "^(?!.*\/(raw|work|quarantine)\/).+"},
    "run_receipt_url": {"type": "string", "minLength": 1},
    "evidence_drawer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot_id","nhd_snapshot_id","spec_hash","manifest_id","timeslice_id","manifest_digest","crosswalk_digest","run_receipt_url","evidence_bundle_uri","release_state"],
      "properties": {
        "snapshot_id": {"type": "string", "minLength": 1},
        "nhd_snapshot_id": {"type": "string", "minLength": 1},
        "spec_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{6,}$"},
        "manifest_id": {"type": "string", "minLength": 1},
        "timeslice_id": {"type": "string", "minLength": 1},
        "manifest_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{6,}$"},
        "crosswalk_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{6,}$"},
        "run_receipt_url": {"type": "string", "minLength": 1},
        "evidence_bundle_uri": {"type": "string", "pattern": "^(?!.*\/(raw|work|quarantine)\/).+"},
        "release_state": {"enum": ["cataloged", "published", "revoked"]}
      }
    }
  }
}
