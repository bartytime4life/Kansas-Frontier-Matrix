{
  "schema": "DataUseGovernanceBundle.v1",
  "bundle_id": "data-use-governance-default",
  "version": "v1",
  "status": "draft",
  "default_posture": {
    "access_decision": "deny_unless_allowed",
    "response_decision": "plan_only",
    "external_notifications": false,
    "require_attribution_when_required": true
  },
  "data_use_policy": {
    "schema": "DataUsePolicy.v1",
    "allowed_actions": [
      "read"
    ],
    "denied_actions": [
      "redistribute_unapproved"
    ],
    "allowed_purposes": [
      "research"
    ],
    "denied_purposes": [
      "bad"
    ],
    "duties": [
      {
        "duty_id": "duty.attribution",
        "required": true,
        "evidence_field": "attribution_present"
      }
    ],
    "prohibitions": [
      {
        "prohibition_id": "p1",
        "action": "redistribute_unapproved",
        "severity": "critical"
      }
    ]
  },
  "data_use_response_policy": {
    "schema": "DataUseResponsePolicy.v1",
    "allowed_response_decisions": [
      "plan_only",
      "notify_consumer",
      "internal_review",
      "recommend_policy_change",
      "recommend_enforcement_change",
      "recommend_trust_status_review",
      "blocked",
      "no_action"
    ],
    "issue_to_response": {
      "denied_action": "blocked",
      "forbidden_action": "blocked",
      "denied_purpose": "internal_review",
      "missing_purpose": "blocked",
      "missing_attribution": "notify_consumer",
      "missing_citation": "notify_consumer",
      "quota_exceeded": "internal_review",
      "burst_usage": "internal_review",
      "high_denial_rate": "internal_review",
      "repeated_blocked_access": "recommend_enforcement_change",
      "critical_anomaly": "recommend_trust_status_review"
    },
    "forbidden_actions": [
      "send_external_notification"
    ]
  },
  "combined_decision_rules": [
    {
      "rule_id": "du.allow_read_research_with_attribution",
      "description": "Allow read-only research use when required attribution evidence is present.",
      "when": {
        "action": "read",
        "purpose": "research",
        "attribution_present": true
      },
      "issue": null,
      "decision": "allow",
      "response_decision": "no_action",
      "severity": "none"
    },
    {
      "rule_id": "du.block_unapproved_redistribution",
      "description": "Block unapproved redistribution because it is both denied and prohibited.",
      "when": {
        "action": "redistribute_unapproved"
      },
      "issue": "forbidden_action",
      "decision": "deny",
      "response_decision": "blocked",
      "severity": "critical"
    },
    {
      "rule_id": "du.block_any_denied_action",
      "description": "Block any action listed in denied_actions.",
      "when": {
        "action_in": [
          "redistribute_unapproved"
        ]
      },
      "issue": "denied_action",
      "decision": "deny",
      "response_decision": "blocked",
      "severity": "critical"
    },
    {
      "rule_id": "du.review_denied_purpose",
      "description": "Deny the use and send the case to internal review when the purpose is explicitly denied.",
      "when": {
        "purpose_in": [
          "bad"
        ]
      },
      "issue": "denied_purpose",
      "decision": "deny",
      "response_decision": "internal_review",
      "severity": "high"
    },
    {
      "rule_id": "du.block_missing_purpose",
      "description": "Block the request when no purpose is supplied.",
      "when": {
        "purpose_missing": true
      },
      "issue": "missing_purpose",
      "decision": "deny",
      "response_decision": "blocked",
      "severity": "high"
    },
    {
      "rule_id": "du.notify_missing_attribution",
      "description": "Do not approve the request until required attribution evidence is present.",
      "when": {
        "required_duty": "duty.attribution",
        "attribution_present": false
      },
      "issue": "missing_attribution",
      "decision": "deny_until_corrected",
      "response_decision": "notify_consumer",
      "severity": "medium"
    },
    {
      "rule_id": "du.notify_missing_citation",
      "description": "Do not approve cite-dependent use until citation support is present.",
      "when": {
        "citation_required": true,
        "citation_present": false
      },
      "issue": "missing_citation",
      "decision": "deny_until_corrected",
      "response_decision": "notify_consumer",
      "severity": "medium"
    },
    {
      "rule_id": "du.review_quota_or_burst_issue",
      "description": "Hold the request for internal review when quota, burst, or suspicious usage thresholds are exceeded.",
      "when": {
        "any_issue_in": [
          "quota_exceeded",
          "burst_usage",
          "high_denial_rate"
        ]
      },
      "issue": "usage_anomaly",
      "decision": "hold_for_review",
      "response_decision": "internal_review",
      "severity": "warning"
    },
    {
      "rule_id": "du.recommend_enforcement_for_repeated_blocked_access",
      "description": "Recommend enforcement change when blocked access repeats.",
      "when": {
        "issue": "repeated_blocked_access"
      },
      "issue": "repeated_blocked_access",
      "decision": "deny",
      "response_decision": "recommend_enforcement_change",
      "severity": "high"
    },
    {
      "rule_id": "du.recommend_trust_review_for_critical_anomaly",
      "description": "Recommend trust status review for critical anomalies.",
      "when": {
        "issue": "critical_anomaly"
      },
      "issue": "critical_anomaly",
      "decision": "deny",
      "response_decision": "recommend_trust_status_review",
      "severity": "critical"
    },
    {
      "rule_id": "du.block_external_notification",
      "description": "Block external notification actions unless a separate approved policy explicitly allows them.",
      "when": {
        "response_action": "send_external_notification"
      },
      "issue": "forbidden_action",
      "decision": "deny",
      "response_decision": "blocked",
      "severity": "critical"
    }
  ],
  "normalizations": [
    {
      "field": "data_use_response_policy.issue_to_response.missing_purpose",
      "from": "forbidden_action",
      "to": "blocked",
      "reason": "issue_to_response values should be allowed response decisions"
    }
  ]
}
