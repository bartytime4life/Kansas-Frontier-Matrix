{
  "schema": "DataUseResponseGovernanceBundle.v1",
  "bundle_id": "data-use-response-governance-soilgrids-strict-local",
  "version": "v1",
  "status": "draft",
  "scope": {
    "data_use_response_id": "dur-1",
    "dataset_id": "soilgrids",
    "response_profile": "strict-local"
  },
  "data_use_response_spec": {
    "schema": "DataUseResponseSpec.v1",
    "data_use_response_id": "dur-1",
    "dataset_id": "soilgrids",
    "response_profile": "strict-local",
    "response_policy": {
      "default_decision": "plan_only",
      "execute_external_notifications": false,
      "require_approval_for_policy_recommendation": true
    },
    "issue_classification": {
      "purpose_violation_severity": "high",
      "obligation_missing_severity": "medium",
      "quota_exceeded_severity": "warning",
      "critical_anomaly_severity": "critical"
    },
    "redaction": {
      "redact_subjects": true
    },
    "source": {
      "require_data_use_receipt_success": true
    }
  },
  "data_use_response_policy": {
    "schema": "DataUseResponsePolicy.v1",
    "allowed_response_decisions": [
      "plan_only",
      "notify_consumer",
      "internal_review",
      "recommend_policy_change",
      "recommend_enforcement_change",
      "recommend_trust_status_review",
      "blocked",
      "no_action"
    ],
    "issue_to_response": {
      "denied_action": "blocked",
      "forbidden_action": "blocked",
      "denied_purpose": "internal_review",
      "missing_purpose": "blocked",
      "missing_attribution": "notify_consumer",
      "missing_citation": "notify_consumer",
      "missing_data_use_receipt": "blocked",
      "quota_exceeded": "internal_review",
      "burst_usage": "internal_review",
      "high_denial_rate": "internal_review",
      "repeated_blocked_access": "recommend_enforcement_change",
      "critical_anomaly": "recommend_trust_status_review"
    },
    "forbidden_actions": [
      "send_external_notification"
    ]
  },
  "effective_controls": {
    "default_response_decision": "plan_only",
    "external_notifications": "disabled",
    "policy_recommendations": "approval_required",
    "subject_redaction": "enabled",
    "data_use_receipt": "required_success",
    "fallback_posture": "block_or_review"
  },
  "decision_rules": [
    {
      "rule_id": "dur.default.strict_local_plan_only",
      "description": "Default to plan-only response behavior for the strict-local profile unless a more specific issue rule applies.",
      "when": {
        "issue_present": false,
        "response_profile": "strict-local"
      },
      "issue": null,
      "response_decision": "plan_only",
      "severity": "none"
    },
    {
      "rule_id": "dur.block.missing_purpose",
      "description": "Block the response when the purpose is missing.",
      "when": {
        "issue": "missing_purpose"
      },
      "issue": "missing_purpose",
      "response_decision": "blocked",
      "severity": "high"
    },
    {
      "rule_id": "dur.review.denied_purpose",
      "description": "Send denied-purpose cases to internal review.",
      "when": {
        "issue": "denied_purpose"
      },
      "issue": "denied_purpose",
      "response_decision": "internal_review",
      "severity": "high"
    },
    {
      "rule_id": "dur.notify.missing_attribution",
      "description": "Notify the consumer when attribution evidence is missing.",
      "when": {
        "issue": "missing_attribution"
      },
      "issue": "missing_attribution",
      "response_decision": "notify_consumer",
      "severity": "medium"
    },
    {
      "rule_id": "dur.notify.missing_citation",
      "description": "Notify the consumer when required citation evidence is missing.",
      "when": {
        "issue": "missing_citation"
      },
      "issue": "missing_citation",
      "response_decision": "notify_consumer",
      "severity": "medium"
    },
    {
      "rule_id": "dur.block.missing_data_use_receipt",
      "description": "Block the response when a successful data-use receipt is required but absent.",
      "when": {
        "issue": "missing_data_use_receipt",
        "require_data_use_receipt_success": true
      },
      "issue": "missing_data_use_receipt",
      "response_decision": "blocked",
      "severity": "high"
    },
    {
      "rule_id": "dur.review.quota_or_usage_anomaly",
      "description": "Send quota, burst, and high-denial-rate usage issues to internal review.",
      "when": {
        "issue_in": [
          "quota_exceeded",
          "burst_usage",
          "high_denial_rate"
        ]
      },
      "issue": "usage_anomaly",
      "response_decision": "internal_review",
      "severity": "warning"
    },
    {
      "rule_id": "dur.recommend.enforcement_change",
      "description": "Recommend enforcement change after repeated blocked access.",
      "when": {
        "issue": "repeated_blocked_access"
      },
      "issue": "repeated_blocked_access",
      "response_decision": "recommend_enforcement_change",
      "severity": "high"
    },
    {
      "rule_id": "dur.recommend.trust_status_review",
      "description": "Recommend trust status review for critical anomalies.",
      "when": {
        "issue": "critical_anomaly"
      },
      "issue": "critical_anomaly",
      "response_decision": "recommend_trust_status_review",
      "severity": "critical"
    },
    {
      "rule_id": "dur.block.external_notification",
      "description": "Block external notification actions because this profile is strict-local and external notification execution is disabled.",
      "when": {
        "action": "send_external_notification"
      },
      "issue": "forbidden_action",
      "response_decision": "blocked",
      "severity": "critical"
    }
  ],
  "normalizations": [
    {
      "field": "data_use_response_policy.issue_to_response.missing_purpose",
      "from": "forbidden_action",
      "to": "blocked",
      "reason": "issue_to_response values should be members of allowed_response_decisions"
    },
    {
      "field": "data_use_response_policy.issue_to_response.denied_action",
      "from": null,
      "to": "blocked",
      "reason": "denied actions should fail closed"
    },
    {
      "field": "data_use_response_policy.issue_to_response.forbidden_action",
      "from": null,
      "to": "blocked",
      "reason": "forbidden actions should fail closed"
    },
    {
      "field": "data_use_response_policy.issue_to_response.missing_data_use_receipt",
      "from": null,
      "to": "blocked",
      "reason": "the spec requires a successful data-use receipt"
    }
  ]
}
