{
  "schema": "WatchtowerSpec.v1",
  "watchtower_id": "soilgrids-watchtower-v1",
  "dataset_id": "soilgrids-v2",
  "log": {"algorithm": "sha256-rfc9162-style", "leaf_domain_separator": "00", "node_domain_separator": "01"},
