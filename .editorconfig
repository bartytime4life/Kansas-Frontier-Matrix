# KFM repository-wide editor defaults.
# EditorConfig normalizes basic text editing only; formatters, validators,
# pre-commit hooks, and CI remain separate and stronger authorities.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Python source and stubs follow Python's four-space convention.
[*.{py,pyi}]
indent_size = 4

# TOML arrays and continuation lines use four-space indentation.
[*.toml]
indent_size = 4

# Keep current structured-data, policy, shell, and web families explicit so a
# future change to the general baseline cannot silently alter their behavior.
[*.{yaml,yml,json,jsonc,geojson,jsonl,ndjson,rego,sh,bash,zsh,js,mjs,cjs,jsx,ts,tsx,css,scss,html,xml,svg}]
indent_size = 2

# Container build files follow the repository's two-space general baseline.
[{Dockerfile,Dockerfile.*,Containerfile,Containerfile.*,*.dockerfile}]
indent_size = 2

# Make recipes require literal tabs; do not replace them with spaces.
[{Makefile,makefile,GNUmakefile,*.mk}]
indent_style = tab
indent_size = tab

# KFM Markdown and MDX may contain long metadata blocks, tables, diagrams,
# and URLs that editors should not wrap automatically.
[*.{md,mdx}]
max_line_length = off
