{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schemas/pmtiles/runreceipt.schema.json",
  "title": "KFM PMTiles Run Receipt",
  "type": "object",
  "required": ["schema_version", "type", "subject", "predicate"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "kfm.runreceipt.pmtiles.v1"},
    "type": {"type": "string"},
    "subject": {"type": "array", "minItems": 1},
    "predicate": {
      "type": "object",
      "required": ["buildDefinition", "runDetails"],
      "properties": {
        "buildDefinition": {
          "type": "object",
          "required": ["buildType", "externalParameters"],
          "properties": {
            "buildType": {"const": "kfm/pmtiles/build@v1"},
            "externalParameters": {
              "type": "object",
              "required": ["spec_hash"],
              "properties": {
                "spec_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"}
              }
            }
          }
        },
        "runDetails": {
          "type": "object",
          "required": ["builder"],
          "properties": {
            "builder": {
              "type": "object",
              "required": ["id"],
              "properties": {"id": {"type": "string", "minLength": 1}}
            }
          }
        }
      }
    }
  }
}
