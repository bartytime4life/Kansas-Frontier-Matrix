{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kfm://schemas/pmtiles/pmsig.schema.json",
  "title": "KFM PMSIG Signature Bundle",
  "type": "object",
  "required": ["schema_version", "subject", "key_id", "signature"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "kfm.pmsig.v1"},
    "subject": {
      "type": "object",
      "required": ["pmtiles_sha256", "pmidx_merkle_root", "spec_hash"],
      "properties": {
        "pmtiles_sha256": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
        "pmidx_merkle_root": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
        "spec_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"}
      }
    },
    "key_id": {"type": "string", "minLength": 1},
    "signature": {"type": "string", "minLength": 1},
    "not_before": {"type": "string"},
    "not_after": {"type": "string"}
  }
}
