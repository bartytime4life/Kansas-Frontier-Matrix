{
  "version": "v1",
  "kind": "SourceDescriptor",
  "identity": {
    "source_id": "example_public_source",
    "title": "Example Public Source",
    "provider": "Example Provider"
  },
  "role_and_scope": {
    "source_role": "direct_observation_measurement",
    "primary_lane": "reference",
    "publication_intent": "fixture_only"
  },
  "access": {
