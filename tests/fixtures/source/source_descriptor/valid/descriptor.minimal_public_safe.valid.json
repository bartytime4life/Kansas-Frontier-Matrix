  },
  "support": {
    "temporal": {
      "basis": "observation_time",
      "documented_intervals": [
        "daily"
      ]
    },
    "spatial": {
      "crs": "EPSG:4326",
      "precision_served": "generalized_fixture"
    }
  },
  "validation": {
    "required_checks": [
      "source_identity_present",
      "source_role_present",
